<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:Atlas.Resources.Converters">

    <!-- ============================================================
         ATLAS shared (theme-independent) resources: converter singletons.
         The COLOR/BRUSH palette lives in AtlasTheme.Dark.xaml / AtlasTheme.Light.xaml
         and is swapped at runtime by ThemeService (Phase 13). Converters never
         change with the theme, so they stay here and are merged once in App.xaml.
         ============================================================ -->

    <!-- Converters (shared singletons) -->
    <conv:BoolToVisibilityConverter   x:Key="BoolToVisibility"/>
    <conv:InverseBoolConverter        x:Key="InverseBool"/>
    <conv:NullToVisibilityConverter   x:Key="NullToVisibility"/>
    <conv:ServerStateToColorConverter x:Key="ServerStateToColor"/>
    <conv:ServerStateToBrushConverter x:Key="ServerStateToBrush"/>
    <conv:EnumToStringConverter       x:Key="EnumToString"/>
    <conv:BytesToMbConverter          x:Key="BytesToMb"/>
    <conv:TimeSpanToStringConverter   x:Key="TimeSpanToString"/>
    <conv:EqualityMultiConverter      x:Key="Equality"/>
    <conv:ModStatusToBrushConverter   x:Key="ModStatusToBrush"/>

</ResourceDictionary>
