<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         ATLAS DARK palette (default). Swapped at runtime against
         AtlasTheme.Light.xaml by ThemeService. Every consumer references
         these brushes via DynamicResource, so replacing this dictionary
         in App.Current.Resources.MergedDictionaries recolors the whole UI.
         Keep the keys IDENTICAL to the Light variant.
         ============================================================ -->

    <!-- Colors -->
    <Color x:Key="Atlas.Color.Background">#FF0D0D0D</Color>
    <Color x:Key="Atlas.Color.Surface">#FF1A1A1A</Color>
    <Color x:Key="Atlas.Color.SurfaceRaised">#FF232323</Color>
    <Color x:Key="Atlas.Color.Border">#FF2A2A2A</Color>
    <Color x:Key="Atlas.Color.Accent">#FFCC2200</Color>
    <Color x:Key="Atlas.Color.AccentHover">#FFFF4422</Color>
    <Color x:Key="Atlas.Color.AccentDisabled">#FF661100</Color>
    <Color x:Key="Atlas.Color.TextPrimary">#FFE8E8E8</Color>
    <Color x:Key="Atlas.Color.TextSecondary">#FF888888</Color>
    <Color x:Key="Atlas.Color.TextDisabled">#FF444444</Color>
    <Color x:Key="Atlas.Color.Success">#FF22CC44</Color>
    <Color x:Key="Atlas.Color.Warning">#FFFFAA00</Color>
    <Color x:Key="Atlas.Color.Error">#FFFF2222</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Atlas.Brush.Background"      Color="{StaticResource Atlas.Color.Background}"/>
    <SolidColorBrush x:Key="Atlas.Brush.Surface"         Color="{StaticResource Atlas.Color.Surface}"/>
    <SolidColorBrush x:Key="Atlas.Brush.SurfaceRaised"   Color="{StaticResource Atlas.Color.SurfaceRaised}"/>
    <SolidColorBrush x:Key="Atlas.Brush.Border"          Color="{StaticResource Atlas.Color.Border}"/>
    <SolidColorBrush x:Key="Atlas.Brush.Accent"          Color="{StaticResource Atlas.Color.Accent}"/>
    <SolidColorBrush x:Key="Atlas.Brush.AccentHover"     Color="{StaticResource Atlas.Color.AccentHover}"/>
    <SolidColorBrush x:Key="Atlas.Brush.AccentDisabled"  Color="{StaticResource Atlas.Color.AccentDisabled}"/>
    <SolidColorBrush x:Key="Atlas.Brush.TextPrimary"     Color="{StaticResource Atlas.Color.TextPrimary}"/>
    <SolidColorBrush x:Key="Atlas.Brush.TextSecondary"   Color="{StaticResource Atlas.Color.TextSecondary}"/>
    <SolidColorBrush x:Key="Atlas.Brush.TextDisabled"    Color="{StaticResource Atlas.Color.TextDisabled}"/>
    <SolidColorBrush x:Key="Atlas.Brush.Success"         Color="{StaticResource Atlas.Color.Success}"/>
    <SolidColorBrush x:Key="Atlas.Brush.Warning"         Color="{StaticResource Atlas.Color.Warning}"/>
    <SolidColorBrush x:Key="Atlas.Brush.Error"           Color="{StaticResource Atlas.Color.Error}"/>

</ResourceDictionary>
