<UserControl x:Class="Atlas.Pages.Dashboard.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="clr-namespace:Atlas.Core.Behaviors"
             Background="{DynamicResource Atlas.Brush.Background}">
    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style x:Key="Hdr" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.Accent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="16">

        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" Text="Dashboard" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"
                   Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Style="{StaticResource Card}" Padding="10,8" Margin="0,12,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource Atlas.Button.Secondary}"
                        Content="Open Full Console" Padding="12,6"
                        Command="{Binding OpenConsoleCommand}"/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
            </DockPanel>
        </Border>

        <!-- Server status + actions -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"
                         Fill="{Binding ServerState, Converter={StaticResource ServerStateToBrush}}"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ServerStateText}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                    <TextBlock Foreground="{DynamicResource Atlas.Brush.TextSecondary}" Margin="0,2,0,0">
                        <Run Text="{Binding ServerName, Mode=OneWay}"/>
                        <Run Text="  •  "/>
                        <Run Text="{Binding ActiveProfileName, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource Atlas.Button.Primary}" Content="Start" Margin="0,0,8,0"
                            Command="{Binding StartCommand}"/>
                    <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Stop" Margin="0,0,8,0"
                            Command="{Binding StopCommand}"/>
                    <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Restart" Margin="0,0,8,0"
                            Command="{Binding RestartCommand}"/>
                    <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Force Kill"
                            Command="{Binding ForceKillCommand}"
                            Visibility="{Binding CanForceKill, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stats row -->
        <UniformGrid DockPanel.Dock="Top" Rows="1" Columns="5" Margin="0,12,0,0">
            <Border Style="{StaticResource Card}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource StatLabel}" Text="UPTIME"/>
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding UptimeText}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="6,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource StatLabel}" Text="PLAYERS"/>
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding PlayerCount}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="6,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource StatLabel}" Text="CPU"/>
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding CpuText}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="6,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource StatLabel}" Text="MEMORY"/>
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding MemoryText}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource StatLabel}" Text="CRASHES"/>
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding CrashCount}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Quick actions (RCON) -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Padding="12,10" Margin="0,12,0,0">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="QUICK ACTIONS" Style="{StaticResource Hdr}" Margin="0" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="RCON:" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                        <TextBlock Text="{Binding RconState}" VerticalAlignment="Center" Margin="0,0,10,0"
                                   Foreground="{DynamicResource Atlas.Brush.TextPrimary}" FontWeight="SemiBold"/>
                        <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Connect" Padding="10,4"
                                Command="{Binding ConnectRconCommand}"/>
                    </StackPanel>
                </DockPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Send RCON message -->
                    <DockPanel Grid.Column="0" Margin="0,0,12,0">
                        <Button DockPanel.Dock="Right" Style="{StaticResource Atlas.Button.Secondary}" Content="Send"
                                Padding="12,5" Margin="6,0,0,0" Command="{Binding SendRconMessageCommand}"/>
                        <TextBox VerticalContentAlignment="Center"
                                 Background="{DynamicResource Atlas.Brush.Surface}"
                                 Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                                 BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" Padding="8,5"
                                 CaretBrush="{DynamicResource Atlas.Brush.TextPrimary}"
                                 Text="{Binding RconMessageInput, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SendRconMessageCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </DockPanel>

                    <!-- Change mission -->
                    <DockPanel Grid.Column="1" Margin="0,0,12,0">
                        <Button DockPanel.Dock="Right" Style="{StaticResource Atlas.Button.Secondary}" Content="Set Mission"
                                Padding="12,5" Margin="6,0,0,0" Command="{Binding ChangeMissionQuickCommand}"/>
                        <ComboBox IsEditable="True" VerticalContentAlignment="Center"
                                  Background="{DynamicResource Atlas.Brush.Surface}"
                                  Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                                  BorderBrush="{DynamicResource Atlas.Brush.Border}"
                                  ItemsSource="{Binding Missions}" Text="{Binding SelectedMission}"/>
                    </DockPanel>

                    <!-- Lock / Unlock / Kick All -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Lock" Padding="12,5" Margin="0,0,6,0"
                                Command="{Binding LockServerQuickCommand}"/>
                        <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Unlock" Padding="12,5" Margin="0,0,6,0"
                                Command="{Binding UnlockServerQuickCommand}"/>
                        <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Kick All" Padding="12,5"
                                Command="{Binding KickAllQuickCommand}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Main: log tail + headless-client panel -->
        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Log tail -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Hdr}"
                               Text="SERVER LOG (RPT TAIL)" Margin="14,12,14,6"/>
                    <ListBox ItemsSource="{Binding LogTail}" Background="Transparent" BorderThickness="0"
                             b:AutoScrollBehavior.StickToBottom="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="14,1"/>
                                <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Headless-client panel -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="12,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Hdr}" Text="HEADLESS CLIENTS"/>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Start All" Margin="0,0,8,0"
                                Padding="10,5" Command="{Binding StartHeadlessClientsCommand}"/>
                        <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Stop All"
                                Padding="10,5" Command="{Binding StopHeadlessClientsCommand}"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding HeadlessClients}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Atlas.Brush.SurfaceRaised}" CornerRadius="4"
                                            Padding="8,6" Margin="0,0,0,6">
                                        <DockPanel>
                                            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                                                     Fill="{Binding State, Converter={StaticResource ServerStateToBrush}}"/>
                                            <TextBlock Text="{Binding State}" DockPanel.Dock="Right" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}" FontSize="11"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
