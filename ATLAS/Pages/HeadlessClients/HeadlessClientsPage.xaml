<UserControl x:Class="Atlas.Pages.HeadlessClients.HeadlessClientsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Atlas.Brush.Background}">
    <UserControl.Resources>
        <Style x:Key="Tool" TargetType="Button" BasedOn="{StaticResource Atlas.Button.Secondary}">
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        <Style x:Key="RowBtn" TargetType="Button" BasedOn="{StaticResource Atlas.Button.Secondary}">
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- No-active-profile overlay -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasActiveProfile, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
            <TextBlock Text="No active profile" FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <TextBlock Text="Activate a profile to manage its headless clients."
                       Margin="0,10,0,0" HorizontalAlignment="Center"
                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
        </StackPanel>

        <DockPanel Margin="16"
                   Visibility="{Binding HasActiveProfile, Converter={StaticResource BoolToVisibility}}">

            <TextBlock DockPanel.Dock="Top" Text="Headless Clients" FontSize="22" FontWeight="SemiBold"
                       Margin="0,0,0,12" Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>

            <!-- Config panel -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.4*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Executable + count + auto-restart -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="HC EXECUTABLE (blank = same as server)"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource Tool}" Content="Browse..." Margin="6,0,0,0"
                                    Command="{Binding BrowseExeCommand}"/>
                            <TextBox Text="{Binding HcExePath, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                        </DockPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <StackPanel Margin="0,0,24,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="COUNT (1–10)"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource RowBtn}" Content="–" Width="30"
                                            Command="{Binding DecrementCountCommand}"/>
                                    <TextBox Text="{Binding HcCount}" Width="56" TextAlignment="Center" VerticalContentAlignment="Center"/>
                                    <Button Style="{StaticResource RowBtn}" Content="+" Width="30" Margin="4,0,0,0"
                                            Command="{Binding IncrementCountCommand}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,4">
                                <CheckBox Content="Auto-restart on crash" IsChecked="{Binding HcAutoRestart}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- HC IPs -->
                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="HC IPs (one per line)"/>
                        <TextBox Text="{Binding HcIpsText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="86"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>

                    <!-- Mods note + Save -->
                    <DockPanel Grid.Column="2">
                        <Button DockPanel.Dock="Bottom" Style="{StaticResource Atlas.Button.Primary}" Content="Save Configuration"
                                Padding="14,7" HorizontalAlignment="Right" Command="{Binding SaveConfigCommand}"/>
                        <TextBlock TextWrapping="Wrap" VerticalAlignment="Top"
                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}" FontSize="11"
                                   Text="Mods: headless clients load every mod flagged &quot;Enabled for Headless&quot; on the Mods page (server-only mods are excluded). Set per-mod targeting there."/>
                    </DockPanel>
                </Grid>
            </Border>

            <!-- Bulk controls -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Style="{StaticResource Atlas.Button.Primary}" Content="Launch All" Margin="0,0,6,0"
                        Padding="14,6" Command="{Binding StartAllCommand}"/>
                <Button Style="{StaticResource Tool}" Content="Stop All" Command="{Binding StopAllCommand}"/>
            </StackPanel>

            <!-- Status footer -->
            <Border DockPanel.Dock="Bottom" Margin="0,10,0,0" Padding="8,6"
                    Background="{DynamicResource Atlas.Brush.Surface}"
                    BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
            </Border>

            <!-- Instance cards -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Instances}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Width="300" Margin="0,0,12,12">
                                <StackPanel>
                                    <DockPanel>
                                        <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Fill="{Binding State, Converter={StaticResource ServerStateToBrush}}"/>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding State}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}" FontSize="11"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15"
                                                   Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                                    </DockPanel>

                                    <UniformGrid Columns="3" Margin="0,10,0,10">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource StatLabel}" Text="PID"/>
                                            <TextBlock Style="{StaticResource StatValue}" Text="{Binding PidText}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource StatLabel}" Text="UPTIME"/>
                                            <TextBlock Style="{StaticResource StatValue}" Text="{Binding UptimeText}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource StatLabel}" Text="CRASHES"/>
                                            <TextBlock Style="{StaticResource StatValue}" Text="{Binding CrashCount}"/>
                                        </StackPanel>
                                    </UniformGrid>

                                    <WrapPanel>
                                        <Button Style="{StaticResource RowBtn}" Content="Start"
                                                Command="{Binding DataContext.StartOneCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Style="{StaticResource RowBtn}" Content="Stop"
                                                Command="{Binding DataContext.StopOneCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Style="{StaticResource RowBtn}" Content="Restart"
                                                Command="{Binding DataContext.RestartOneCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Style="{StaticResource RowBtn}" Content="View Log"
                                                Command="{Binding DataContext.ViewLogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
