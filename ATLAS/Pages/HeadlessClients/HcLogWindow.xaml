<Window x:Class="Atlas.Pages.HeadlessClients.HcLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:b="clr-namespace:Atlas.Core.Behaviors"
        Width="820" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Atlas.Brush.Background}"
        TextElement.Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
        Title="Headless Client Log">
    <DockPanel Margin="12">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Style="{StaticResource Atlas.Button.Secondary}" Content="Open Folder"
                    Padding="10,5" Margin="6,0,0,0" Click="OnOpenFolder"/>
            <Button DockPanel.Dock="Right" Style="{StaticResource Atlas.Button.Secondary}" Content="Clear"
                    Padding="10,5" Click="OnClear"/>
            <TextBlock x:Name="HeaderText" VerticalAlignment="Center" FontWeight="SemiBold"
                       Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
        </DockPanel>
        <Border Background="{DynamicResource Atlas.Brush.Surface}"
                BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="LogList" Background="Transparent" BorderThickness="0"
                     FontFamily="Consolas" FontSize="12"
                     b:AutoScrollBehavior.StickToBottom="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,1"/>
                        <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>
    </DockPanel>
</Window>
