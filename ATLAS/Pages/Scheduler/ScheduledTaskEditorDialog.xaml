<Window x:Class="Atlas.Pages.Scheduler.ScheduledTaskEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Scheduled Task" Width="560" Height="640"
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Atlas.Brush.SurfaceRaised}"
        TextElement.Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI" FontSize="13">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,12,0,3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource Atlas.ComboBox}">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1">
        <DockPanel>
            <!-- Title bar (draggable) -->
            <Border x:Name="HeaderBar" DockPanel.Dock="Top" Height="44"
                    Background="{DynamicResource Atlas.Brush.Surface}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="{Binding DialogTitle}" Margin="16,0" VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                    <Button HorizontalAlignment="Right" Width="44" Style="{StaticResource Atlas.Button.Nav}"
                            Command="{Binding CancelCommand}" ToolTip="Close">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Footer -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource Atlas.Brush.Surface}" Padding="16,10">
                <DockPanel>
                    <TextBlock Text="{Binding ValidationError}" VerticalAlignment="Center"
                               Foreground="{DynamicResource Atlas.Brush.Error}" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Cancel" Padding="16,7"
                                Margin="0,0,8,0" Command="{Binding CancelCommand}"/>
                        <Button Style="{StaticResource Atlas.Button.Primary}" Content="Save" Padding="16,7"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Body -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,8">
                <StackPanel>
                    <TextBlock Style="{StaticResource Lbl}" Text="NAME"/>
                    <TextBox Text="{Binding TaskName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Style="{StaticResource Lbl}" Text="TYPE"/>
                    <ComboBox ItemsSource="{Binding TaskTypes}" SelectedItem="{Binding SelectedType}"/>

                    <TextBlock Style="{StaticResource Lbl}" Text="SCHEDULE (interpreted in local time)"/>
                    <ComboBox ItemsSource="{Binding ScheduleModes}" SelectedItem="{Binding ScheduleMode}"/>

                    <!-- Daily -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                Visibility="{Binding IsDaily, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="At" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="70" ItemsSource="{Binding Hours}" SelectedItem="{Binding TimeHour}"/>
                        <TextBlock Text=":" VerticalAlignment="Center" Margin="6,0"/>
                        <ComboBox Width="70" ItemsSource="{Binding Minutes}" SelectedItem="{Binding TimeMinute}"/>
                    </StackPanel>

                    <!-- Weekly -->
                    <StackPanel Visibility="{Binding IsWeekly, Converter={StaticResource BoolToVisibility}}">
                        <WrapPanel Margin="0,8,0,0">
                            <CheckBox Content="Mon" Margin="0,0,12,0" IsChecked="{Binding DayMon}"/>
                            <CheckBox Content="Tue" Margin="0,0,12,0" IsChecked="{Binding DayTue}"/>
                            <CheckBox Content="Wed" Margin="0,0,12,0" IsChecked="{Binding DayWed}"/>
                            <CheckBox Content="Thu" Margin="0,0,12,0" IsChecked="{Binding DayThu}"/>
                            <CheckBox Content="Fri" Margin="0,0,12,0" IsChecked="{Binding DayFri}"/>
                            <CheckBox Content="Sat" Margin="0,0,12,0" IsChecked="{Binding DaySat}"/>
                            <CheckBox Content="Sun" IsChecked="{Binding DaySun}"/>
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="At" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Width="70" ItemsSource="{Binding Hours}" SelectedItem="{Binding TimeHour}"/>
                            <TextBlock Text=":" VerticalAlignment="Center" Margin="6,0"/>
                            <ComboBox Width="70" ItemsSource="{Binding Minutes}" SelectedItem="{Binding TimeMinute}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Interval -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                Visibility="{Binding IsInterval, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Every" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="70" ItemsSource="{Binding IntervalChoices}" SelectedItem="{Binding IntervalHours}"/>
                        <TextBlock Text="hour(s)" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Advanced (raw cron) -->
                    <StackPanel Visibility="{Binding IsAdvanced, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Style="{StaticResource Lbl}" Text="CRON EXPRESSION (5-field)"/>
                        <TextBox Text="{Binding Cron, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas"/>
                    </StackPanel>

                    <TextBlock Text="{Binding CronPreview}" Margin="0,8,0,0"
                               Foreground="{DynamicResource Atlas.Brush.Accent}" TextWrapping="Wrap"/>

                    <!-- Restart / Update &amp; Restart: shared countdown -->
                    <StackPanel Visibility="{Binding ShowCountdown, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Style="{StaticResource Lbl}" Text="BEFORE RESTARTING"
                                   Visibility="{Binding IsUpdateRestart, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}" FontSize="11"
                                   Visibility="{Binding IsUpdateRestart, Converter={StaticResource BoolToVisibility}}"
                                   Text="Updates the Arma server and this profile's Workshop mods (SteamCMD), then restarts."/>
                        <CheckBox Content="Broadcast a countdown over RCON before restarting"
                                  IsChecked="{Binding CountdownEnabled}"/>
                        <TextBlock Style="{StaticResource Lbl}" Text="WARNING MESSAGE ({minutes} is substituted)"/>
                        <TextBox Text="{Binding WarningMessage, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Style="{StaticResource Lbl}" Text="WARN AT (minutes before, comma-separated)"/>
                        <TextBox Text="{Binding MinutesWarningsText, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas"/>
                    </StackPanel>

                    <!-- Message -->
                    <StackPanel Visibility="{Binding IsMessage, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Style="{StaticResource Lbl}" Text="MESSAGE TO BROADCAST"/>
                        <TextBox Text="{Binding BroadcastMessage, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- RconCommand -->
                    <StackPanel Visibility="{Binding IsRconCommand, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Style="{StaticResource Lbl}" Text="RCON COMMAND (e.g. #lock)"/>
                        <TextBox Text="{Binding RconCommandText, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas"/>
                    </StackPanel>

                    <CheckBox Content="Enabled" IsChecked="{Binding IsEnabledOnSave}" Margin="0,16,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
