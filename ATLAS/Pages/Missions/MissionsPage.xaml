<UserControl x:Class="Atlas.Pages.Missions.MissionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Atlas.Brush.Background}">
    <UserControl.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>
        <Style x:Key="Hdr" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.Accent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,6,0,6"/>
        </Style>
        <Style x:Key="Tool" TargetType="Button" BasedOn="{StaticResource Atlas.Button.Secondary}">
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource Atlas.ComboBox}">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- No-active-profile overlay -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasActiveProfile, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
            <TextBlock Text="No active profile" FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <TextBlock Text="Activate a profile on the Profiles page to browse its missions."
                       Margin="0,10,0,0" HorizontalAlignment="Center"
                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
        </StackPanel>

        <!-- Main content -->
        <DockPanel Margin="16"
                   Visibility="{Binding HasActiveProfile, Converter={StaticResource BoolToVisibility}}">

            <!-- Header + toolbar -->
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="Missions" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>

                <DockPanel Margin="0,0,0,8">
                    <Button DockPanel.Dock="Right" Style="{StaticResource Atlas.Button.Primary}"
                            Content="Set as Active Mission" Margin="6,0,0,0"
                            Command="{Binding SetActiveMissionCommand}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource Atlas.Button.Secondary}"
                            Content="Open Mission Folder" Margin="6,0,0,0"
                            Command="{Binding OpenMissionFolderCommand}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource Atlas.Button.Secondary}"
                            Content="Refresh" Margin="6,0,0,0"
                            Command="{Binding LoadCommand}"/>

                    <TextBox Width="220" HorizontalAlignment="Left" VerticalAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    <ComboBox Width="160" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0"
                              ItemsSource="{Binding Terrains}" SelectedItem="{Binding SelectedTerrain}"/>
                    <TextBlock Text="Search / filter by terrain" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                </DockPanel>
            </StackPanel>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="8,6"
                    Background="{DynamicResource Atlas.Brush.Surface}"
                    BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <ProgressBar DockPanel.Dock="Right" Width="160" Height="6" IsIndeterminate="True"
                                 VerticalAlignment="Center" Margin="8,0,0,0"
                                 Foreground="{DynamicResource Atlas.Brush.Accent}"
                                 Background="{DynamicResource Atlas.Brush.SurfaceRaised}"
                                 BorderThickness="0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                </DockPanel>
            </Border>

            <!-- Center: mission grid + detail/params panel -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Mission grid -->
                <Border Grid.Column="0" Background="{DynamicResource Atlas.Brush.Surface}"
                        BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
                    <DataGrid ItemsSource="{Binding Missions}" SelectedItem="{Binding SelectedMission}"
                              AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal" Background="Transparent" BorderThickness="0"
                              RowBackground="{DynamicResource Atlas.Brush.Surface}"
                              Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                              HorizontalGridLinesBrush="{DynamicResource Atlas.Brush.Border}">
                        <DataGrid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick"
                                          Command="{Binding SetActiveMissionCommand}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Accent}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Accent}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mission Name" Binding="{Binding MissionName}" Width="*"/>
                            <DataGridTextColumn Header="Terrain" Binding="{Binding Terrain}" Width="120"/>
                            <DataGridTextColumn Header="Size"
                                                Binding="{Binding FileSizeBytes, Converter={StaticResource BytesToMb}}"
                                                Width="80"/>
                            <DataGridTextColumn Header="Last Modified"
                                                Binding="{Binding LastModified, StringFormat=yyyy-MM-dd HH:mm}"
                                                Width="130"/>
                            <DataGridTextColumn Header="Source" Binding="{Binding SourceFolder}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Detail + params panel -->
                <Border Grid.Column="1" Margin="12,0,0,0" Padding="12"
                        Background="{DynamicResource Atlas.Brush.Surface}"
                        BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Selected-mission detail (only when a mission is selected) -->
                            <StackPanel Visibility="{Binding SelectedMission, Converter={StaticResource NullToVisibility}}">
                                <TextBlock Text="{Binding SelectedMission.MissionName}" FontSize="16" FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>

                                <TextBlock Style="{StaticResource Lbl}" Text="Terrain"/>
                                <TextBlock Text="{Binding SelectedMission.Terrain}" TextWrapping="Wrap"
                                           Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>

                                <TextBlock Style="{StaticResource Lbl}" Text="Players (hint)"/>
                                <TextBlock Text="{Binding SelectedMission.PlayerCountHint}"
                                           Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>

                                <TextBlock Style="{StaticResource Lbl}" Text="Full PBO name"/>
                                <TextBlock Text="{Binding SelectedMission.FullPboName}" TextWrapping="Wrap"
                                           Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>

                                <TextBlock Style="{StaticResource Lbl}" Text="Size"/>
                                <TextBlock Text="{Binding SelectedMission.FileSizeBytes, Converter={StaticResource BytesToMb}}"
                                           Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>

                                <TextBlock Style="{StaticResource Lbl}" Text="Last Modified"/>
                                <TextBlock Text="{Binding SelectedMission.LastModified, StringFormat=yyyy-MM-dd HH:mm}"
                                           Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>

                                <TextBlock Style="{StaticResource Lbl}" Text="Source"/>
                                <TextBlock Text="{Binding SelectedMission.SourceFolder}"
                                           Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                            </StackPanel>

                            <!-- Mission parameters (bound to the active profile) -->
                            <TextBlock Style="{StaticResource Hdr}" Text="MISSION PARAMETERS" Margin="0,16,0,6"/>

                            <TextBlock Style="{StaticResource Lbl}" Text="Difficulty"/>
                            <ComboBox ItemsSource="{Binding DifficultyOptions}"
                                      SelectedItem="{Binding Profile.MissionDifficulty, Mode=TwoWay}"/>

                            <CheckBox Content="Auto-init" Margin="0,12,0,0"
                                      IsChecked="{Binding Profile.AutoInit, Mode=TwoWay}"/>
                            <CheckBox Content="Persistent"
                                      IsChecked="{Binding Profile.Persistent, Mode=TwoWay}"/>

                            <TextBlock Text="Saved when you click Set as Active Mission."
                                       Margin="0,12,0,0" TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
