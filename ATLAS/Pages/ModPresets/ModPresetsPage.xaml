<UserControl x:Class="Atlas.Pages.ModPresets.ModPresetsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Atlas.Brush.Background}">
    <UserControl.Resources>
        <Style x:Key="Tool" TargetType="Button" BasedOn="{StaticResource Atlas.Button.Secondary}">
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===================== Left: preset list ===================== -->
        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock DockPanel.Dock="Top" Text="Mod Presets" FontSize="22" FontWeight="SemiBold"
                       Margin="0,0,0,12" Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <WrapPanel DockPanel.Dock="Top">
                <Button Style="{StaticResource Tool}" Content="New" Command="{Binding NewPresetCommand}"/>
                <Button Style="{StaticResource Tool}" Content="Clone" Command="{Binding ClonePresetCommand}"/>
                <Button Style="{StaticResource Tool}" Content="Delete" Command="{Binding DeletePresetCommand}"/>
                <Button Style="{StaticResource Tool}" Content="Import A3" Command="{Binding ImportA3Command}"/>
                <Button Style="{StaticResource Tool}" Content="Export A3" Command="{Binding ExportA3Command}"/>
            </WrapPanel>
            <Border Background="{DynamicResource Atlas.Brush.Surface}"
                    BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
                <ListView ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}"
                          Background="Transparent" BorderThickness="0" Foreground="{DynamicResource Atlas.Brush.TextPrimary}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                                <TextBlock FontSize="11" Margin="0,2,0,0"
                                           Foreground="{DynamicResource Atlas.Brush.TextSecondary}"
                                           Text="{Binding Mods.Count, StringFormat='{}{0} mods'}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </DockPanel>

        <!-- ===================== Right: detail ===================== -->
        <DockPanel Grid.Column="1">
            <StackPanel DockPanel.Dock="Top"
                        Visibility="{Binding SelectedPreset, Converter={StaticResource NullToVisibility}}">
                <TextBlock Text="Preset name" FontSize="12" Margin="0,0,0,3"
                           Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                <TextBox Text="{Binding SelectedPreset.Name}" Background="{DynamicResource Atlas.Brush.Surface}"
                         Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                         BorderBrush="{DynamicResource Atlas.Brush.Border}" Padding="8,5"
                         CaretBrush="{DynamicResource Atlas.Brush.TextPrimary}"/>
                <TextBlock Text="Description" FontSize="12" Margin="0,8,0,3"
                           Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                <TextBox Text="{Binding SelectedPreset.Description}" Background="{DynamicResource Atlas.Brush.Surface}"
                         Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                         BorderBrush="{DynamicResource Atlas.Brush.Border}" Padding="8,5"
                         CaretBrush="{DynamicResource Atlas.Brush.TextPrimary}"/>

                <WrapPanel Margin="0,12,0,8">
                    <Button Style="{StaticResource Tool}" Content="Add Workshop" Command="{Binding AddByWorkshopCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Add Local" Command="{Binding AddLocalCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Remove" Command="{Binding RemoveModCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Move Up" Command="{Binding MoveUpCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Move Down" Command="{Binding MoveDownCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Open in Workshop" Command="{Binding OpenInWorkshopCommand}"/>
                </WrapPanel>
            </StackPanel>

            <!-- Bottom action buttons -->
            <WrapPanel DockPanel.Dock="Bottom" Margin="0,10,0,0"
                       Visibility="{Binding SelectedPreset, Converter={StaticResource NullToVisibility}}">
                <Button Style="{StaticResource Atlas.Button.Primary}" Content="Save Preset" Margin="0,0,8,0"
                        Command="{Binding SavePresetCommand}"/>
                <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Apply to Active Profile" Margin="0,0,8,0"
                        Command="{Binding ApplyToActiveProfileCommand}"/>
                <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Save Active Profile's Mods as New Preset"
                        Command="{Binding CreateFromActiveProfileCommand}"/>
            </WrapPanel>

            <!-- Mod grid -->
            <Border Background="{DynamicResource Atlas.Brush.Surface}"
                    BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4"
                    Margin="0,4,0,0">
                <DataGrid ItemsSource="{Binding Mods}" SelectedItem="{Binding SelectedMod}"
                          AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" Background="Transparent" BorderThickness="0"
                          RowBackground="{DynamicResource Atlas.Brush.Surface}"
                          Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                          HorizontalGridLinesBrush="{DynamicResource Atlas.Brush.Border}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding LoadOrder}" IsReadOnly="True" Width="40"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Workshop ID" Binding="{Binding WorkshopId}" IsReadOnly="True" Width="120"/>
                        <DataGridTextColumn Header="Version" Binding="{Binding Version}" IsReadOnly="True" Width="80"/>
                        <DataGridCheckBoxColumn Header="Local" Binding="{Binding IsLocal}" IsReadOnly="True" Width="55"/>
                        <DataGridCheckBoxColumn Header="Server" Binding="{Binding EnabledForServer}" Width="60"/>
                        <DataGridCheckBoxColumn Header="Client" Binding="{Binding EnabledForClient}" Width="60"/>
                        <DataGridCheckBoxColumn Header="HC" Binding="{Binding EnabledForHeadless}" Width="50"/>
                        <DataGridCheckBoxColumn Header="Optional" Binding="{Binding IsOptional}" Width="65"/>
                        <DataGridCheckBoxColumn Header="Srv-only" Binding="{Binding IsServerOnly}" Width="65"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
