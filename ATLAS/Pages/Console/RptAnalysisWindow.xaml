<Window x:Class="Atlas.Pages.Console.RptAnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="720" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Atlas.Brush.Background}"
        Title="RPT Analysis">
    <DockPanel Margin="12">
        <TextBlock x:Name="HeaderText" DockPanel.Dock="Top" FontWeight="SemiBold" TextWrapping="Wrap"
                   Margin="0,0,0,4" Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
        <TextBlock x:Name="SummaryText" DockPanel.Dock="Top" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"
                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
        <Border Background="{DynamicResource Atlas.Brush.Surface}"
                BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                <ItemsControl x:Name="FindingsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="6,4" IsExpanded="False">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <Border CornerRadius="3" Padding="6,1" Margin="0,0,8,0"
                                                Background="{Binding SeverityBrush}">
                                            <TextBlock Text="{Binding SeverityText}" FontSize="10" FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                                        <TextBlock Text="{Binding CountText}" Margin="8,0,0,0"
                                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="26,4,8,8">
                                    <TextBlock Text="{Binding Guidance}" TextWrapping="Wrap" Margin="0,0,0,6"
                                               Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                                    <ItemsControl ItemsSource="{Binding Samples}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                                           TextWrapping="Wrap" Margin="0,1"
                                                           Foreground="{DynamicResource Atlas.Brush.TextDisabled}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
