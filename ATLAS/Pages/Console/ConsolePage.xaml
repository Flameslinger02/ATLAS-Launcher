<UserControl x:Class="Atlas.Pages.Console.ConsolePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="clr-namespace:Atlas.Core.Behaviors"
             Background="{DynamicResource Atlas.Brush.Background}">
    <UserControl.Resources>
        <Style x:Key="Tool" TargetType="Button" BasedOn="{StaticResource Atlas.Button.Secondary}">
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource Atlas.ComboBox}">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Padding="14,8" Margin="0,0,4,0"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LogLine" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="DBG">
                    <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="VRB">
                    <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="WRN">
                    <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.Warning}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="ERR">
                    <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.Error}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="FTL">
                    <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.Error}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16,12,16,16">
        <!-- ===== Console = logs + updates ===== -->
        <TabControl Background="Transparent" BorderThickness="0" SelectedIndex="{Binding SelectedTabIndex}">

            <!-- ATLAS App Log -->
            <TabItem Header="ATLAS Log" DataContext="{Binding AppLog}">
                <DockPanel Margin="0,8,0,0">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Style="{StaticResource Tool}" Content="Export" Margin="0"
                                Command="{Binding ExportCommand}"/>
                        <Button DockPanel.Dock="Right" Style="{StaticResource Tool}" Content="Clear"
                                Command="{Binding ClearCommand}"/>
                        <CheckBox DockPanel.Dock="Right" Content="Pause" IsChecked="{Binding IsPaused}"/>
                        <TextBox Width="220" HorizontalAlignment="Left" VerticalContentAlignment="Center"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <ComboBox Width="120" Margin="8,0,0,0" HorizontalAlignment="Left"
                                  ItemsSource="{Binding LevelOptions}" SelectedItem="{Binding MinLevel}"/>
                        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                    </DockPanel>
                    <Border Background="{DynamicResource Atlas.Brush.Surface}"
                            BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
                        <ListBox x:Name="AppLogList" ItemsSource="{Binding Entries}" Background="Transparent" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="12"
                                 b:AutoScrollBehavior.StickToBottom="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="10,1"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}" Style="{StaticResource LogLine}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- Server RPT tail -->
            <TabItem Header="Server RPT">
                <DockPanel Margin="0,8,0,0">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Style="{StaticResource Tool}" Content="Open in Explorer" Margin="0"
                                Command="{Binding OpenRptInExplorerCommand}"/>
                        <Button DockPanel.Dock="Right" Style="{StaticResource Tool}" Content="Save to File"
                                Command="{Binding SaveRptCommand}"/>
                        <Button DockPanel.Dock="Right" Style="{StaticResource Tool}" Content="Clear"
                                Command="{Binding ClearServerRptCommand}"/>
                        <Button DockPanel.Dock="Right" Style="{StaticResource Tool}" Content="Analyze"
                                Command="{Binding AnalyzeRptCommand}"
                                ToolTip="Scan the newest RPT log on disk for known errors (missing addons, signature kicks, script errors, crashes) with guidance"/>
                        <TextBlock Text="Live tail of the running server's .rpt log."
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                    </DockPanel>
                    <Border Background="{DynamicResource Atlas.Brush.Surface}"
                            BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
                        <ListBox x:Name="ServerRptList" ItemsSource="{Binding ServerRpt}" Background="Transparent" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="12"
                                 b:AutoScrollBehavior.StickToBottom="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="10,1"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- Updates (Arma 3 server + ATLAS launcher) -->
            <TabItem Header="Updates" DataContext="{Binding Updater}">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ATLAS launcher -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="ATLAS Launcher"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Current:" Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                                <TextBlock Text="{Binding CurrentVersionText}" Margin="6,0,16,0"
                                           Foreground="{DynamicResource Atlas.Brush.TextPrimary}" FontWeight="SemiBold"/>
                                <TextBlock Text="Latest:" Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                                <TextBlock Text="{Binding LatestVersionText}" Margin="6,0,0,0"
                                           Foreground="{DynamicResource Atlas.Brush.TextPrimary}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource Atlas.Button.Primary}" Content="Update ATLAS" Padding="14,6"
                                        Command="{Binding UpdateAtlasCommand}"/>
                                <ProgressBar Width="180" Height="8" Margin="12,0,0,0" VerticalAlignment="Center"
                                             Minimum="0" Maximum="1" Value="{Binding AtlasProgress}"
                                             Visibility="{Binding IsUpdatingAtlas, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="{Binding AtlasStatus}" VerticalAlignment="Center" Margin="12,0,0,0"
                                           Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                            </StackPanel>
                            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"
                                       Text="Downloads the latest portable build, then closes and relaunches ATLAS automatically."/>
                        </StackPanel>
                    </Border>

                    <!-- Arma 3 server -->
                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="Arma 3 Dedicated Server"/>
                            <DockPanel Margin="0,0,0,8">
                                <Button DockPanel.Dock="Right" Style="{StaticResource Tool}" Content="Browse…" Margin="6,0,0,0"
                                        Command="{Binding BrowseArmaDirCommand}"/>
                                <TextBox Text="{Binding ArmaServerDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource Atlas.Button.Primary}" Content="Install / Update Server" Padding="14,6"
                                        Command="{Binding UpdateArmaCommand}"/>
                                <Button Style="{StaticResource Tool}" Content="Cancel" Margin="8,0,0,0"
                                        Command="{Binding CancelArmaCommand}"/>
                                <CheckBox Content="Profiling branch" Margin="12,0,0,0"
                                          IsChecked="{Binding UseProfilingBranch}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- SteamCMD output -->
                    <Border Grid.Row="2" Margin="0,12,0,0"
                            Background="{DynamicResource Atlas.Brush.Surface}"
                            BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
                        <ListBox x:Name="ArmaOutputList" ItemsSource="{Binding ArmaOutput}" Background="Transparent" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="12"
                                 b:AutoScrollBehavior.StickToBottom="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="10,1"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
