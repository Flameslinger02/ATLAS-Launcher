<UserControl x:Class="Atlas.Pages.Mods.ModsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="clr-namespace:Atlas.Core.Behaviors"
             Background="{DynamicResource Atlas.Brush.Background}">
    <UserControl.Resources>
        <Style x:Key="Tool" TargetType="Button" BasedOn="{StaticResource Atlas.Button.Secondary}">
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
    </UserControl.Resources>

    <TabControl Margin="8" Background="Transparent" BorderThickness="0">

        <!-- ============================================================ Mod Library -->
        <TabItem Header="Mod Library">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- download directory -->
                    <RowDefinition Height="Auto"/>   <!-- directory hint -->
                    <RowDefinition Height="Auto"/>   <!-- add bar -->
                    <RowDefinition Height="Auto"/>   <!-- toolbar -->
                    <RowDefinition Height="*"/>      <!-- registry grid -->
                    <RowDefinition Height="Auto"/>   <!-- deploy panel -->
                    <RowDefinition Height="170"/>    <!-- output -->
                </Grid.RowDefinitions>

                <!-- Mod download directory (where SteamCMD downloads Workshop mods) -->
                <DockPanel Grid.Row="0" Margin="0,0,0,2">
                    <TextBlock DockPanel.Dock="Left" Text="Mod download dir:" VerticalAlignment="Center"
                               Margin="0,0,8,0" Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource Tool}" Content="Browse…"
                            Command="{Binding BrowseModDirectoryCommand}" Margin="8,0,0,0"/>
                    <TextBox Text="{Binding ModDirectory}" VerticalContentAlignment="Center" Padding="8,5"
                             Background="{DynamicResource Atlas.Brush.Surface}"
                             Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                             BorderBrush="{DynamicResource Atlas.Brush.Border}"
                             CaretBrush="{DynamicResource Atlas.Brush.TextPrimary}"
                             ToolTip="The folder SteamCMD downloads Workshop mods into. Point it at your existing mod folder to avoid re-downloading."/>
                </DockPanel>

                <!-- Directory hint -->
                <TextBlock Grid.Row="1" Margin="0,0,0,8" TextWrapping="Wrap" FontSize="11"
                           Foreground="{DynamicResource Atlas.Brush.TextSecondary}"
                           Text="Point this at the folder that CONTAINS steamapps\workshop\content\107410 — usually your Steam install root (e.g. C:\Program Files (x86)\Steam), NOT the !Workshop folder. ATLAS reads/downloads mods there; deploying into a profile's server folder (below) is separate."/>

                <!-- Add by Workshop URL / ID -->
                <DockPanel Grid.Row="2" Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Left" Text="Add mod:" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource Atlas.Button.Primary}"
                            Content="Add &amp; Download" Command="{Binding AddAndDownloadCommand}" Margin="8,0,0,0"/>
                    <TextBox Text="{Binding AddModInput, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="8,5"
                             Background="{DynamicResource Atlas.Brush.Surface}"
                             Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                             BorderBrush="{DynamicResource Atlas.Brush.Border}"
                             CaretBrush="{DynamicResource Atlas.Brush.TextPrimary}"
                             ToolTip="Paste a Steam Workshop URL or a numeric item ID"/>
                </DockPanel>

                <!-- Library actions -->
                <WrapPanel Grid.Row="3">
                    <Button Style="{StaticResource Tool}" Content="Log in to Steam" Command="{Binding SteamLoginCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Refresh" Command="{Binding LoadLibraryCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Check for Updates" Command="{Binding CheckForUpdatesCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Update Outdated" Command="{Binding UpdateOutdatedCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Update Selected" Command="{Binding UpdateSelectedCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Remove Selected" Command="{Binding RemoveSelectedCommand}"/>
                    <TextBlock Text="{Binding LibraryStatus}" VerticalAlignment="Center" Margin="8,0,0,6"
                               Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                </WrapPanel>

                <!-- Registry grid + selected-mod detail card -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource Atlas.Brush.Surface}"
                        BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
                    <DataGrid ItemsSource="{Binding Library}" SelectedItem="{Binding SelectedLibraryRow, Mode=TwoWay}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="Transparent"
                              BorderThickness="0" RowBackground="{DynamicResource Atlas.Brush.Surface}"
                              Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                              HorizontalGridLinesBrush="{DynamicResource Atlas.Brush.Border}">
                        <DataGrid.Columns>
                            <!-- Template-column checkbox (interactive in a non-editing grid; see DataGrid gotcha) -->
                            <DataGridTemplateColumn Header="✓" Width="34" MinWidth="30">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox HorizontalAlignment="Center"
                                                  IsChecked="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- Fixed-pixel widths + MinWidth, matching the Presets grid — the standard
                                 resize feel (drag a divider, neighbours give way; columns keep their width). -->
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="240" MinWidth="160"/>
                            <DataGridTextColumn Header="Workshop ID" Binding="{Binding WorkshopIdText}" IsReadOnly="True" Width="120" MinWidth="88"/>
                            <DataGridTextColumn Header="Version" Binding="{Binding Version}" IsReadOnly="True" Width="80" MinWidth="56"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" IsReadOnly="True" Width="80" MinWidth="60"/>
                            <DataGridTextColumn Header="Updated" Binding="{Binding LastUpdatedText}" IsReadOnly="True" Width="100" MinWidth="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" IsReadOnly="True" Width="120" MinWidth="90"/>
                            <DataGridTextColumn Header="Used by" Binding="{Binding UsedBy}" IsReadOnly="True" Width="180" MinWidth="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    </Border>

                    <!-- Selected-mod detail card -->
                    <Border Grid.Column="1" Margin="12,0,0,0" Background="{DynamicResource Atlas.Brush.Surface}"
                            BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4"
                            Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel Margin="12">
                            <TextBlock DockPanel.Dock="Top" Text="{Binding DetailName}" FontWeight="SemiBold"
                                       FontSize="14" TextWrapping="Wrap"
                                       Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                            <Border DockPanel.Dock="Top" Margin="0,8,0,0" MaxHeight="150" CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    Visibility="{Binding HasDetailImage, Converter={StaticResource BoolToVisibility}}">
                                <Image Source="{Binding DetailImageUrl}" Stretch="Uniform" StretchDirection="DownOnly"/>
                            </Border>
                            <TextBlock DockPanel.Dock="Top" Text="{Binding DetailMeta}" Margin="0,8,0,0" FontSize="11"
                                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                            <TextBlock DockPanel.Dock="Top" Text="{Binding DetailInfo}" Margin="0,8,0,0"
                                       TextWrapping="Wrap" Foreground="{DynamicResource Atlas.Brush.Accent}"/>
                            <Button DockPanel.Dock="Bottom" Style="{StaticResource Tool}" Content="View on Workshop"
                                    Margin="0,8,0,0" HorizontalAlignment="Left"
                                    Command="{Binding OpenSelectedInWorkshopCommand}"
                                    Visibility="{Binding HasWorkshopId, Converter={StaticResource BoolToVisibility}}"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                                <TextBlock Text="{Binding DetailDescription}" TextWrapping="Wrap" FontSize="12"
                                           Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- Deploy / verify a profile's mods -->
                <DockPanel Grid.Row="5" Margin="0,8,0,8" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left" Text="Deploy / verify profile:" VerticalAlignment="Center"
                               Margin="0,0,8,0" Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                    <ComboBox DockPanel.Dock="Left" Width="200" VerticalAlignment="Center"
                              ItemsSource="{Binding Profiles}" SelectedItem="{Binding TargetProfile}"
                              DisplayMemberPath="Name"/>
                    <Button DockPanel.Dock="Left" Style="{StaticResource Tool}" Content="Deploy"
                            Command="{Binding DeployCommand}" Margin="8,0,6,0"/>
                    <Button DockPanel.Dock="Left" Style="{StaticResource Tool}" Content="Clean Stale Links"
                            Command="{Binding CleanupStaleCommand}"/>
                    <Button DockPanel.Dock="Left" Style="{StaticResource Tool}" Content="Check Keys"
                            Command="{Binding CheckKeyConflictsCommand}"/>
                </DockPanel>

                <!-- Live SteamCMD / deploy output -->
                <Border Grid.Row="6" Background="{DynamicResource Atlas.Brush.Surface}"
                        BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
                    <DockPanel Margin="6">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                            <Button DockPanel.Dock="Right" Style="{StaticResource Tool}" Content="Cancel"
                                    Command="{Binding CancelCommand}" Margin="0"/>
                            <TextBlock Text="Output" FontWeight="SemiBold" VerticalAlignment="Center"
                                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                        </DockPanel>
                        <ListBox ItemsSource="{Binding Output}" Background="Transparent" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="12"
                                 Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                                 b:AutoScrollBehavior.StickToBottom="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Border>
            </Grid>
        </TabItem>

        <!-- ============================================================ Presets -->
        <TabItem Header="Presets">
            <Grid Margin="8" DataContext="{Binding Presets}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: preset list -->
                <DockPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock DockPanel.Dock="Top" Text="Mod Presets" FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,8" Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                    <WrapPanel DockPanel.Dock="Top">
                        <Button Style="{StaticResource Tool}" Content="New" Command="{Binding NewPresetCommand}"/>
                        <Button Style="{StaticResource Tool}" Content="Clone" Command="{Binding ClonePresetCommand}"/>
                        <Button Style="{StaticResource Tool}" Content="Delete" Command="{Binding DeletePresetCommand}"/>
                        <Button Style="{StaticResource Tool}" Content="Import A3" Command="{Binding ImportA3Command}"/>
                        <Button Style="{StaticResource Tool}" Content="Export A3" Command="{Binding ExportA3Command}"/>
                    </WrapPanel>
                    <Border Background="{DynamicResource Atlas.Brush.Surface}"
                            BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
                        <ListView ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}"
                                  Background="Transparent" BorderThickness="0"
                                  Foreground="{DynamicResource Atlas.Brush.TextPrimary}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                                        <TextBlock FontSize="11" Margin="0,2,0,0"
                                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}"
                                                   Text="{Binding Mods.Count, StringFormat='{}{0} mods'}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </DockPanel>

                <!-- Right: detail -->
                <DockPanel Grid.Column="1">
                    <StackPanel DockPanel.Dock="Top"
                                Visibility="{Binding SelectedPreset, Converter={StaticResource NullToVisibility}}">
                        <TextBlock Text="Preset name" FontSize="12" Margin="0,0,0,3"
                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                        <TextBox Text="{Binding SelectedPreset.Name}" Background="{DynamicResource Atlas.Brush.Surface}"
                                 Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                                 BorderBrush="{DynamicResource Atlas.Brush.Border}" Padding="8,5"
                                 CaretBrush="{DynamicResource Atlas.Brush.TextPrimary}"/>
                        <TextBlock Text="Description" FontSize="12" Margin="0,8,0,3"
                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                        <TextBox Text="{Binding SelectedPreset.Description}" Background="{DynamicResource Atlas.Brush.Surface}"
                                 Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                                 BorderBrush="{DynamicResource Atlas.Brush.Border}" Padding="8,5"
                                 CaretBrush="{DynamicResource Atlas.Brush.TextPrimary}"/>

                        <WrapPanel Margin="0,12,0,8">
                            <Button Style="{StaticResource Tool}" Content="Add from Library" Command="{Binding AddFromLibraryCommand}"
                                    ToolTip="Pick mods ATLAS already knows about — no need to paste Workshop IDs again"/>
                            <Button Style="{StaticResource Tool}" Content="Add Workshop" Command="{Binding AddByWorkshopCommand}"/>
                            <Button Style="{StaticResource Tool}" Content="Add Local" Command="{Binding AddLocalCommand}"/>
                            <Button Style="{StaticResource Tool}" Content="Remove" Command="{Binding RemoveModCommand}"/>
                            <Button Style="{StaticResource Tool}" Content="Move Up" Command="{Binding MoveUpCommand}"/>
                            <Button Style="{StaticResource Tool}" Content="Move Down" Command="{Binding MoveDownCommand}"/>
                            <Button Style="{StaticResource Tool}" Content="Open in Workshop" Command="{Binding OpenInWorkshopCommand}"/>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Bottom action buttons -->
                    <WrapPanel DockPanel.Dock="Bottom" Margin="0,10,0,0"
                               Visibility="{Binding SelectedPreset, Converter={StaticResource NullToVisibility}}">
                        <Button Style="{StaticResource Atlas.Button.Primary}" Content="Save Preset" Margin="0,0,8,0"
                                Command="{Binding SavePresetCommand}"/>
                        <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Apply to Active Profile" Margin="0,0,8,0"
                                Command="{Binding ApplyToActiveProfileCommand}"/>
                        <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Save Active Profile's Mods as New Preset"
                                Command="{Binding CreateFromActiveProfileCommand}"/>
                    </WrapPanel>

                    <!-- Mod grid -->
                    <Border Background="{DynamicResource Atlas.Brush.Surface}"
                            BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4"
                            Margin="0,4,0,0">
                        <DataGrid ItemsSource="{Binding Mods}" SelectedItem="{Binding SelectedMod}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal" Background="Transparent" BorderThickness="0"
                                  RowBackground="{DynamicResource Atlas.Brush.Surface}"
                                  Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                                  HorizontalGridLinesBrush="{DynamicResource Atlas.Brush.Border}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding LoadOrder}" IsReadOnly="True" Width="44" MinWidth="36"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="240" MinWidth="120"/>
                                <DataGridTextColumn Header="Workshop ID" Binding="{Binding WorkshopId}" IsReadOnly="True" Width="120" MinWidth="88"/>
                                <DataGridTextColumn Header="Version" Binding="{Binding Version}" IsReadOnly="True" Width="80" MinWidth="56"/>
                                <DataGridCheckBoxColumn Header="Local" Binding="{Binding IsLocal}" IsReadOnly="True" Width="55" MinWidth="46"/>
                                <DataGridCheckBoxColumn Header="Server" Binding="{Binding EnabledForServer}" Width="60" MinWidth="54"/>
                                <DataGridCheckBoxColumn Header="Client" Binding="{Binding EnabledForClient}" Width="60" MinWidth="54"/>
                                <DataGridCheckBoxColumn Header="HC" Binding="{Binding EnabledForHeadless}" Width="50" MinWidth="42"/>
                                <DataGridCheckBoxColumn Header="Optional" Binding="{Binding IsOptional}" Width="65" MinWidth="58"/>
                                <DataGridCheckBoxColumn Header="Srv-only" Binding="{Binding IsServerOnly}" Width="65" MinWidth="58"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </DockPanel>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
