<UserControl x:Class="Atlas.Pages.Mods.ModsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Atlas.Brush.Background}">
    <UserControl.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>
        <Style x:Key="Hdr" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.Accent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,6,0,6"/>
        </Style>
        <Style x:Key="Tool" TargetType="Button" BasedOn="{StaticResource Atlas.Button.Secondary}">
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- No-active-profile overlay -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasActiveProfile, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
            <TextBlock Text="No active profile" FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <TextBlock Text="Activate a profile on the Profiles page to edit its mod list."
                       Margin="0,10,0,0" HorizontalAlignment="Center"
                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
        </StackPanel>

        <!-- Main content -->
        <DockPanel Margin="16"
                   Visibility="{Binding HasActiveProfile, Converter={StaticResource BoolToVisibility}}">

            <!-- Header + preset row -->
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="Mods" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                <DockPanel Margin="0,0,0,8">
                    <Button DockPanel.Dock="Right" Style="{StaticResource Atlas.Button.Primary}"
                            Content="Save" Margin="6,0,0,0" Command="{Binding SaveCommand}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource Atlas.Button.Secondary}"
                            Content="Save as Preset" Margin="6,0,0,0" Command="{Binding SaveAsPresetCommand}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource Atlas.Button.Secondary}"
                            Content="Detach" Margin="6,0,0,0" Command="{Binding DetachPresetCommand}"/>
                    <ComboBox Width="260" HorizontalAlignment="Left" VerticalAlignment="Center"
                              ItemsSource="{Binding PresetChoices}" DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedPresetChoice}"/>
                    <TextBlock Text="{Binding PresetInfo}" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                </DockPanel>

                <!-- Toolbar -->
                <WrapPanel Margin="0,0,0,4">
                    <Button Style="{StaticResource Tool}" Content="Add Workshop" Command="{Binding AddByWorkshopCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Add Local" Command="{Binding AddLocalCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Import A3" Command="{Binding ImportA3Command}"/>
                    <Button Style="{StaticResource Tool}" Content="Check for Updates" Command="{Binding CheckForUpdatesCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Update Selected" Command="{Binding UpdateSelectedCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Update All" Command="{Binding UpdateAllCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Deploy Mods" Command="{Binding DeployModsCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Copy Keys" Command="{Binding CopyKeysCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Remove" Command="{Binding RemoveModCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Move Up" Command="{Binding MoveUpCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Move Down" Command="{Binding MoveDownCommand}"/>
                    <Button Style="{StaticResource Tool}" Content="Open in Workshop" Command="{Binding OpenInWorkshopCommand}"/>
                </WrapPanel>
            </StackPanel>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="8,6"
                    Background="{DynamicResource Atlas.Brush.Surface}"
                    BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Cancel" Style="{StaticResource Atlas.Button.Secondary}"
                            Margin="8,0,0,0" Command="{Binding CancelCommand}"
                            Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisibility}}"/>
                    <ProgressBar DockPanel.Dock="Right" Width="160" Height="6" IsIndeterminate="True"
                                 VerticalAlignment="Center" Margin="8,0,0,0"
                                 Foreground="{DynamicResource Atlas.Brush.Accent}"
                                 Background="{DynamicResource Atlas.Brush.SurfaceRaised}"
                                 BorderThickness="0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding ModSummary}" VerticalAlignment="Center"
                               Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="16,0,0,0"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                </DockPanel>
            </Border>

            <!-- Center: mod grid + detail panel -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- Mod grid -->
                <Border Grid.Column="0" Background="{DynamicResource Atlas.Brush.Surface}"
                        BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
                    <DataGrid ItemsSource="{Binding Mods}" SelectedItem="{Binding SelectedMod}"
                              AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal" Background="Transparent" BorderThickness="0"
                              RowBackground="{DynamicResource Atlas.Brush.Surface}"
                              Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                              HorizontalGridLinesBrush="{DynamicResource Atlas.Brush.Border}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding LoadOrder}" IsReadOnly="True" Width="40"/>
                            <DataGridTemplateColumn Header="" Width="28" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <MultiBinding Converter="{StaticResource ModStatusToBrush}">
                                                    <Binding Path="LastChecked"/>
                                                    <Binding Path="UpdateAvailable"/>
                                                </MultiBinding>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Workshop ID" Binding="{Binding WorkshopId}" IsReadOnly="True" Width="110"/>
                            <DataGridCheckBoxColumn Header="Local" Binding="{Binding IsLocal}" IsReadOnly="True" Width="50"/>
                            <DataGridTextColumn Header="Version" Binding="{Binding Version}" IsReadOnly="True" Width="70"/>
                            <DataGridTextColumn Header="Last Updated"
                                                Binding="{Binding LastUpdated, StringFormat=yyyy-MM-dd}"
                                                IsReadOnly="True" Width="100"/>
                            <DataGridTextColumn Header="Size"
                                                Binding="{Binding SteamFileSize, Converter={StaticResource BytesToMb}}"
                                                IsReadOnly="True" Width="70"/>
                            <DataGridCheckBoxColumn Header="Server" Binding="{Binding EnabledForServer}" Width="60"/>
                            <DataGridCheckBoxColumn Header="Client" Binding="{Binding EnabledForClient}" Width="60"/>
                            <DataGridCheckBoxColumn Header="HC" Binding="{Binding EnabledForHeadless}" Width="50"/>
                            <DataGridCheckBoxColumn Header="Optional" Binding="{Binding IsOptional}" Width="65"/>
                            <DataGridCheckBoxColumn Header="Srv-only" Binding="{Binding IsServerOnly}" Width="65"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Detail panel -->
                <Border Grid.Column="1" Margin="12,0,0,0" Padding="12"
                        Background="{DynamicResource Atlas.Brush.Surface}"
                        BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4"
                        Visibility="{Binding SelectedMod, Converter={StaticResource NullToVisibility}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedMod.Name}" FontSize="16" FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"
                                       Text="{Binding SelectedMod.WorkshopId, StringFormat='Workshop ID: {0}'}"/>
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"
                                       Text="{Binding SelectedMod.IsLocal, StringFormat='Local: {0}'}"/>

                            <Image MaxHeight="160" Margin="0,10,0,0" Stretch="Uniform"
                                   HorizontalAlignment="Left"
                                   Source="{Binding SelectedModInfo.PreviewUrl}"
                                   Visibility="{Binding SelectedModInfo, Converter={StaticResource NullToVisibility}}"/>

                            <TextBlock Style="{StaticResource Lbl}" Text="Description"/>
                            <TextBlock Text="{Binding SelectedModInfo.Description}" TextWrapping="Wrap"
                                       Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>

                            <TextBlock Style="{StaticResource Lbl}" Text="Local path"/>
                            <TextBlock Text="{Binding SelectedMod.LocalPath}" TextWrapping="Wrap"
                                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>

                            <Button Content="Force Re-download" Margin="0,14,0,0" HorizontalAlignment="Left"
                                    Style="{StaticResource Atlas.Button.Secondary}"
                                    Command="{Binding ForceRedownloadCommand}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
