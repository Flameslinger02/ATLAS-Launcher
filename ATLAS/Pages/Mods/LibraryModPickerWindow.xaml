<Window x:Class="Atlas.Pages.Mods.LibraryModPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="480" Height="540"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Atlas.Brush.Background}"
        Title="Add from Library">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="Tick the library mods to add:" Margin="0,0,0,6"
                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
        <TextBox DockPanel.Dock="Top" x:Name="FilterBox" Margin="0,0,0,8" Padding="6,4"
                 VerticalContentAlignment="Center" TextChanged="OnFilterChanged"
                 Background="{DynamicResource Atlas.Brush.Surface}"
                 Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                 BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1"
                 CaretBrush="{DynamicResource Atlas.Brush.TextPrimary}"
                 ToolTip="Filter by name, folder or Workshop ID"/>
        <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <TextBlock x:Name="CountText" VerticalAlignment="Center"
                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource Atlas.Button.Primary}" Content="Add Selected"
                        Padding="14,6" Click="OnAdd"/>
                <Button Style="{StaticResource Atlas.Button.Secondary}" Content="Cancel"
                        Padding="14,6" Margin="8,0,0,0" Click="OnCancel"/>
            </StackPanel>
        </DockPanel>
        <Border Background="{DynamicResource Atlas.Brush.Surface}"
                BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="ModList" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="8,3"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsChecked}" Checked="OnRowToggled" Unchecked="OnRowToggled">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                                <TextBlock Text="{Binding Detail}" FontSize="11"
                                           Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                            </StackPanel>
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </DockPanel>
</Window>
