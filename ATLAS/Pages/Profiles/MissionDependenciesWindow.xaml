<Window x:Class="Atlas.Pages.Profiles.MissionDependenciesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Atlas.Brush.Background}"
        Title="Mission Dependencies">
    <DockPanel Margin="12">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Style="{StaticResource Atlas.Button.Secondary}" Content="Copy All"
                    Padding="10,5" Margin="6,0,0,0" Click="OnCopyAll"/>
            <TextBlock x:Name="HeaderText" VerticalAlignment="Center" FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
        </DockPanel>
        <TextBlock DockPanel.Dock="Bottom" Margin="0,8,0,0" TextWrapping="Wrap" FontSize="11"
                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}"
                   Text="CfgPatches class names the mission requires (addOns[] from mission.sqm). Base-game entries (A3_*) need no mods; the rest must be provided by loaded mods or DLC."/>
        <Border Background="{DynamicResource Atlas.Brush.Surface}"
                BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="DepsList" Background="Transparent" BorderThickness="0"
                     FontFamily="Consolas" FontSize="12"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,1"/>
                        <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>
    </DockPanel>
</Window>
