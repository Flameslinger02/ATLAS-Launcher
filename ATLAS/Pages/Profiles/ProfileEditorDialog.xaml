<Window x:Class="Atlas.Pages.Profiles.ProfileEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Profile Editor" Width="740" Height="680"
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Atlas.Brush.SurfaceRaised}"
        TextElement.Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI" FontSize="13">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>
        <Style x:Key="Hdr" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.Accent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,6,0,6"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1">
        <DockPanel>
            <!-- Title bar (draggable) -->
            <Border x:Name="HeaderBar" DockPanel.Dock="Top" Height="44"
                    Background="{DynamicResource Atlas.Brush.Surface}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="{Binding DialogTitle}" Margin="16,0" VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                    <Button HorizontalAlignment="Right" Width="44" Style="{StaticResource Atlas.Button.Nav}"
                            Command="{Binding CancelCommand}" ToolTip="Close">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Footer -->
            <Border DockPanel.Dock="Bottom" Padding="16,10"
                    Background="{DynamicResource Atlas.Brush.Surface}"
                    BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="0,1,0,0">
                <Grid>
                    <Button HorizontalAlignment="Left" Style="{StaticResource Atlas.Button.Secondary}"
                            Command="{Binding TestLaunchArgsCommand}" Content="Test Launch Args"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource Atlas.Button.Secondary}" Command="{Binding CancelCommand}"
                                Content="Cancel" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource Atlas.Button.Primary}" Command="{Binding SaveCommand}"
                                Content="Save"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tabs -->
            <TabControl Background="Transparent" BorderThickness="0" Padding="0">
                <!-- General -->
                <TabItem Header="General">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Style="{StaticResource Hdr}" Text="IDENTITY"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Profile name"/>
                            <TextBox Text="{Binding Profile.Name}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Server name (hostname)"/>
                            <TextBox Text="{Binding Profile.ServerName}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Game type"/>
                            <TextBox Text="Arma 3" IsReadOnly="True"/>
                            <CheckBox Content="Set as default profile" IsChecked="{Binding Profile.IsDefault}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Notes"/>
                            <TextBox Text="{Binding Profile.Notes}" AcceptsReturn="True" TextWrapping="Wrap"
                                     Height="90" VerticalScrollBarVisibility="Auto"/>

                            <TextBlock Style="{StaticResource Hdr}" Text="MOD PRESET" Margin="0,16,0,6"/>
                            <ComboBox ItemsSource="{Binding PresetChoices}" DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedPresetChoice}"
                                      Width="340" HorizontalAlignment="Left"/>
                            <TextBlock Text="{Binding PresetInfo}" TextWrapping="Wrap" FontSize="11" Margin="0,6,0,0"
                                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                            <Button Content="Detach from Preset" Style="{StaticResource Atlas.Button.Secondary}"
                                    Margin="0,8,0,0" HorizontalAlignment="Left"
                                    Command="{Binding DetachPresetCommand}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Launch Params -->
                <TabItem Header="Launch Params">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Style="{StaticResource Hdr}" Text="EXECUTABLE"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Server executable"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Browse" Margin="8,0,0,0"
                                        Style="{StaticResource Atlas.Button.Secondary}"
                                        Command="{Binding BrowseServerExeCommand}"/>
                                <TextBox Text="{Binding Profile.ServerExecutablePath}"/>
                            </DockPanel>
                            <TextBlock Style="{StaticResource Lbl}" Text="Server directory"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Browse" Margin="8,0,0,0"
                                        Style="{StaticResource Atlas.Button.Secondary}"
                                        Command="{Binding BrowseServerDirCommand}"/>
                                <TextBox Text="{Binding Profile.ServerDirectory}"/>
                            </DockPanel>
                            <CheckBox Content="Use Profiling Branch (arma3server_profiling_x64.exe)"
                                      IsChecked="{Binding Profile.UseProfilingBranch}"/>

                            <TextBlock Style="{StaticResource Hdr}" Text="PARAMETERS" Margin="0,16,0,6"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Arma profile name (-name)"/>
                            <TextBox Text="{Binding Profile.ArmaProfileName}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Game port"/>
                            <TextBox Text="{Binding Profile.Port}" Width="120" HorizontalAlignment="Left"/>
                            <CheckBox Content="BattlEye anti-cheat" IsChecked="{Binding Profile.EnableBattlEye}"/>
                            <CheckBox Content="File patching (-filePatching)" IsChecked="{Binding Profile.FilePatching}"/>
                            <CheckBox Content="No sound (-nosound)" IsChecked="{Binding Profile.NoSound}"/>
                            <CheckBox Content="No splash (-nosplash)" IsChecked="{Binding Profile.NoSplash}"/>
                            <CheckBox Content="Skip intro (-skipIntro)" IsChecked="{Binding Profile.SkipIntro}"/>
                            <CheckBox Content="World empty (-world=empty)" IsChecked="{Binding Profile.WorldEmpty}"/>
                            <CheckBox Content="No pause (-noPause)" IsChecked="{Binding Profile.NoPause}"/>
                            <CheckBox Content="No logs (-nologs)" IsChecked="{Binding Profile.NoLogs}"/>
                            <CheckBox Content="Net log (-netlog)" IsChecked="{Binding Profile.NetLog}"/>
                            <CheckBox Content="Load mission to memory" IsChecked="{Binding Profile.LoadMissionToMemory}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Network -->
                <TabItem Header="Network">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Style="{StaticResource Hdr}" Text="CONNECTION LIMITS"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Max ping"/>
                            <TextBox Text="{Binding Profile.MaxPing}" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Max desync"/>
                            <TextBox Text="{Binding Profile.MaxDesync}" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Max packet loss"/>
                            <TextBox Text="{Binding Profile.MaxPacketLoss}" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Min bandwidth (bps)"/>
                            <TextBox Text="{Binding Profile.MinBandwidth}" Width="200" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Max bandwidth (bps)"/>
                            <TextBox Text="{Binding Profile.MaxBandwidth}" Width="200" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Disconnect timeout (s)"/>
                            <TextBox Text="{Binding Profile.DisconnectTimeout}" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Max disconnect timeout (s)"/>
                            <TextBox Text="{Binding Profile.MaxDisconnectTimeout}" Width="120" HorizontalAlignment="Left"/>
                            <CheckBox Content="Loopback" IsChecked="{Binding Profile.Loopback}"/>

                            <TextBlock Style="{StaticResource Hdr}" Text="RCON (BATTLEYE)" Margin="0,16,0,6"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="RCON password"/>
                            <TextBox Text="{Binding Profile.RconPassword}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="RCON port"/>
                            <TextBox Text="{Binding Profile.RconPort}" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Text="Do not use 2302-2306 (reserved by the game). Defaults: 2301, 2307, 2310."
                                       Foreground="{DynamicResource Atlas.Brush.Warning}" FontSize="11" Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Security -->
                <TabItem Header="Security">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Style="{StaticResource Hdr}" Text="SECURITY"/>
                            <CheckBox Content="BattlEye anti-cheat" IsChecked="{Binding Profile.EnableBattlEye}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Verify signatures (0 = off, 1 = v1, 2 = v2)"/>
                            <ComboBox ItemsSource="{Binding VerifySignaturesOptions}"
                                      SelectedItem="{Binding Profile.VerifySignatures}"
                                      Width="120" HorizontalAlignment="Left"/>
                            <CheckBox Content="Kick duplicate IDs" IsChecked="{Binding Profile.KickDuplicates}"/>
                            <CheckBox Content="Require secure ID" IsChecked="{Binding Profile.RequiredSecureId}"/>
                            <CheckBox Content="File patching" IsChecked="{Binding Profile.FilePatching}"/>
                            <TextBlock Text="⚠ Enable file patching only for trusted private servers."
                                       Foreground="{DynamicResource Atlas.Brush.Warning}" FontSize="11"
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Performance -->
                <TabItem Header="Performance">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Style="{StaticResource Hdr}" Text="PERFORMANCE"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="CPU count (0 = auto)"/>
                            <TextBox Text="{Binding Profile.CpuCount}" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Extra threads (-exThreads)"/>
                            <ComboBox ItemsSource="{Binding ExThreadsOptions}"
                                      SelectedItem="{Binding Profile.ExThreads}" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Max memory MB (0 = auto)"/>
                            <TextBox Text="{Binding Profile.MaxMem}" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Malloc (e.g. mimalloc_v203_LockPages)"/>
                            <TextBox Text="{Binding Profile.Malloc}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Bandwidth algorithm"/>
                            <ComboBox ItemsSource="{Binding BandwidthAlgOptions}"
                                      SelectedItem="{Binding Profile.BandwidthAlg}" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Limit FPS (0 = no limit)"/>
                            <TextBox Text="{Binding Profile.LimitFPS}" Width="120" HorizontalAlignment="Left"/>
                            <CheckBox Content="Enable hyper-threading (-enableHT)" IsChecked="{Binding Profile.EnableHT}"/>
                            <CheckBox Content="Huge pages (-hugePages)" IsChecked="{Binding Profile.HugePages}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Voice & Voting -->
                <TabItem Header="Voice &amp; Voting">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Style="{StaticResource Hdr}" Text="VOICE"/>
                            <CheckBox Content="Disable VoN (voice over net)" IsChecked="{Binding Profile.DisableVoN}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="VoN codec quality (0-30)"/>
                            <StackPanel Orientation="Horizontal">
                                <Slider x:Name="VonSlider" Minimum="0" Maximum="30" Width="260"
                                        Value="{Binding Profile.VonCodecQuality}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Value, ElementName=VonSlider, StringFormat=N0}"
                                           Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Style="{StaticResource Hdr}" Text="VOTING" Margin="0,16,0,6"/>
                            <CheckBox Content="Voting enabled" IsChecked="{Binding Profile.VotingEnabled}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Vote threshold (0.0 - 1.0)"/>
                            <TextBox Text="{Binding Profile.VoteThreshold}" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Vote mission players"/>
                            <TextBox Text="{Binding Profile.VoteMissionPlayers}" Width="120" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Headless -->
                <TabItem Header="Headless">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Style="{StaticResource Hdr}" Text="HEADLESS CLIENTS"/>
                            <CheckBox Content="Use headless clients" IsChecked="{Binding Profile.UseHeadlessClients}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Headless client count"/>
                            <TextBox Text="{Binding Profile.HeadlessClientCount}" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Headless client executable (blank = same as server)"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Browse" Margin="8,0,0,0"
                                        Style="{StaticResource Atlas.Button.Secondary}"
                                        Command="{Binding BrowseHeadlessExeCommand}"/>
                                <TextBox Text="{Binding Profile.HeadlessClientExecutablePath}"/>
                            </DockPanel>
                            <CheckBox Content="Auto-restart headless clients on crash"
                                      IsChecked="{Binding Profile.HeadlessAutoRestart}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Advanced -->
                <TabItem Header="Advanced">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Style="{StaticResource Hdr}" Text="ACCESS"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Server password (join)"/>
                            <TextBox Text="{Binding Profile.ServerPassword}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Admin password"/>
                            <TextBox Text="{Binding Profile.AdminPassword}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Max players"/>
                            <TextBox Text="{Binding Profile.MaxPlayers}" Width="120" HorizontalAlignment="Left"/>

                            <TextBlock Style="{StaticResource Hdr}" Text="MOTD" Margin="0,16,0,6"/>
                            <TextBox Text="{Binding MotdText}" AcceptsReturn="True" TextWrapping="Wrap"
                                     Height="80" VerticalScrollBarVisibility="Auto"/>
                            <TextBlock Text="One line per row." Foreground="{DynamicResource Atlas.Brush.TextDisabled}"
                                       FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="MOTD interval (s)"/>
                            <TextBox Text="{Binding Profile.MotdInterval}" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Log file name"/>
                            <TextBox Text="{Binding Profile.LogFile}"/>

                            <TextBlock Style="{StaticResource Hdr}" Text="MISSION" Margin="0,16,0,6"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Mission name (template)"/>
                            <TextBox Text="{Binding Profile.MissionName}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Difficulty"/>
                            <ComboBox ItemsSource="{Binding DifficultyOptions}"
                                      SelectedItem="{Binding Profile.MissionDifficulty}" Width="160" HorizontalAlignment="Left"/>
                            <CheckBox Content="Auto-init persistent mission" IsChecked="{Binding Profile.AutoInit}"/>
                            <CheckBox Content="Persistent" IsChecked="{Binding Profile.Persistent}"/>

                            <TextBlock Style="{StaticResource Hdr}" Text="CRASH BEHAVIOR" Margin="0,16,0,6"/>
                            <CheckBox Content="Auto-restart on crash" IsChecked="{Binding Profile.AutoRestartOnCrash}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Auto-restart delay (s)"/>
                            <TextBox Text="{Binding Profile.AutoRestartDelaySeconds}" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Max crashes before giving up (0 = unlimited)"/>
                            <TextBox Text="{Binding Profile.MaxCrashesBeforeGiveUp}" Width="120" HorizontalAlignment="Left"/>

                            <TextBlock Style="{StaticResource Hdr}" Text="MISC" Margin="0,16,0,6"/>
                            <CheckBox Content="Enable debug console" IsChecked="{Binding Profile.EnableDebugConsole}"/>
                            <TextBlock Text="⚠ Debug console allows clients to run script — use only on trusted servers."
                                       Foreground="{DynamicResource Atlas.Brush.Error}" FontSize="11"
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                            <CheckBox Content="Short timestamp in logs" IsChecked="{Binding Profile.TimeStampFormat}"/>
                            <CheckBox Content="Allow drawing in map" IsChecked="{Binding Profile.DrawingInMap}"/>
                            <CheckBox Content="Ranking enabled" IsChecked="{Binding Profile.RankingEnabled}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Ranking file"/>
                            <TextBox Text="{Binding Profile.RankingFile}"/>

                            <TextBlock Style="{StaticResource Hdr}" Text="CUSTOM" Margin="0,16,0,6"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Custom launch parameters (appended verbatim)"/>
                            <TextBox Text="{Binding Profile.CustomLaunchParameters}" AcceptsReturn="True"
                                     TextWrapping="Wrap" Height="60" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </DockPanel>
    </Border>
</Window>
