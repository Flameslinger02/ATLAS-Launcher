<UserControl x:Class="Atlas.Pages.Profiles.ProfilesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource Atlas.Brush.Background}">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="Profiles" FontSize="22" FontWeight="SemiBold"
                   Margin="0,0,0,12" Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>

        <!-- Toolbar -->
        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <WrapPanel.Resources>
                <Style TargetType="Button" BasedOn="{StaticResource Atlas.Button.Secondary}">
                    <Setter Property="Margin" Value="0,0,8,8"/>
                </Style>
            </WrapPanel.Resources>
            <Button Content="New" Command="{Binding NewProfileCommand}"/>
            <Button Content="Edit" Command="{Binding EditProfileCommand}"/>
            <Button Content="Clone" Command="{Binding CloneProfileCommand}"/>
            <Button Content="Delete" Command="{Binding DeleteProfileCommand}"/>
            <Button Content="Set Default" Command="{Binding SetDefaultCommand}"/>
            <Button Content="Export" Command="{Binding ExportProfileCommand}"/>
            <Button Content="Import" Command="{Binding ImportProfileCommand}"/>
            <Button Content="Refresh" Command="{Binding LoadCommand}"/>
            <Button Content="Activate" Style="{StaticResource Atlas.Button.Primary}" Margin="0,0,8,8"
                    Command="{Binding ActivateCommand}"/>
        </WrapPanel>

        <!-- Profile list -->
        <Border Background="{DynamicResource Atlas.Brush.Surface}"
                BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4">
            <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                     Background="Transparent" BorderThickness="0" Padding="4"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditProfileCommand}"/>
                </ListBox.InputBindings>
                <ListBox.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Edit" Command="{Binding EditProfileCommand}"/>
                        <MenuItem Header="Activate" Command="{Binding ActivateCommand}"/>
                        <MenuItem Header="Set as Default" Command="{Binding SetDefaultCommand}"/>
                        <Separator/>
                        <MenuItem Header="Clone…" Command="{Binding CloneProfileCommand}"/>
                        <MenuItem Header="Export…" Command="{Binding ExportProfileCommand}"/>
                        <Separator/>
                        <MenuItem Header="Delete" Command="{Binding DeleteProfileCommand}"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10" Margin="2" CornerRadius="3" BorderThickness="2"
                                Background="{DynamicResource Atlas.Brush.SurfaceRaised}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource Equality}">
                                                    <Binding Path="Id"/>
                                                    <Binding Path="DataContext.ActiveProfileId"
                                                             RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Accent}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Star" Width="16" Height="16" VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource Atlas.Brush.Warning}"
                                                                 Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibility}}"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                   Margin="6,0,0,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ServerName}" FontSize="11" Margin="0,3,0,0"
                                               Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <Border Background="{DynamicResource Atlas.Brush.Background}" CornerRadius="8"
                                            Padding="8,2" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding GameType}" FontSize="10"
                                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                                    </Border>
                                    <TextBlock Text="{Binding UpdatedAt, StringFormat='Updated {0:yyyy-MM-dd HH:mm}'}"
                                               FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource Atlas.Brush.TextDisabled}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </DockPanel>
</UserControl>
