<UserControl x:Class="Atlas.Pages.Profiles.ProfilesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource Atlas.Brush.Background}">
    <DockPanel Margin="16">
        <!-- Header + actions -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Profiles" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="New Profile" Style="{StaticResource Atlas.Button.Primary}"
                        Command="{Binding NewProfileCommand}" Margin="0,0,8,0"/>
                <Button Content="Import" Style="{StaticResource Atlas.Button.Secondary}"
                        Command="{Binding ImportProfileCommand}"/>
            </StackPanel>
        </DockPanel>

        <!-- Empty state -->
        <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasProfiles, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
            <TextBlock Text="No profiles yet" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"
                       Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <TextBlock Text="Create one with “New Profile” or import an .atlasprofile."
                       Margin="0,8,0,0" HorizontalAlignment="Center"
                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
        </StackPanel>

        <!-- All profiles laid out as cards -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Profiles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="320" Margin="0,0,12,12" Padding="14" CornerRadius="6" BorderThickness="2"
                                Background="{DynamicResource Atlas.Brush.Surface}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource Equality}">
                                                    <Binding Path="Id"/>
                                                    <Binding Path="DataContext.ActiveProfileId"
                                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Accent}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Star" Width="16" Height="16" VerticalAlignment="Center"
                                                             Foreground="{DynamicResource Atlas.Brush.Warning}"
                                                             Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15"
                                               Margin="6,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ServerName}" FontSize="12" Margin="0,4,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                                <TextBlock Text="{Binding UpdatedAt, StringFormat='Updated {0:yyyy-MM-dd HH:mm}'}"
                                           FontSize="11" Margin="0,2,0,0"
                                           Foreground="{DynamicResource Atlas.Brush.TextDisabled}"/>
                                <WrapPanel Margin="0,10,0,0">
                                    <WrapPanel.Resources>
                                        <Style TargetType="Button" BasedOn="{StaticResource Atlas.Button.Secondary}">
                                            <Setter Property="Margin" Value="0,0,6,6"/>
                                            <Setter Property="Padding" Value="9,4"/>
                                        </Style>
                                    </WrapPanel.Resources>
                                    <Button Content="Open" Style="{StaticResource Atlas.Button.Primary}" Margin="0,0,6,6"
                                            Command="{Binding DataContext.OpenProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Set Default"
                                            Command="{Binding DataContext.SetDefaultCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Clone"
                                            Command="{Binding DataContext.CloneProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Export"
                                            Command="{Binding DataContext.ExportProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Delete"
                                            Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
