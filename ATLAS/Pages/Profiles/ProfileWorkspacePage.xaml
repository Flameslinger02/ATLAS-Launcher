<UserControl x:Class="Atlas.Pages.Profiles.ProfileWorkspacePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource Atlas.Brush.Background}">
    <UserControl.Resources>
        <!-- Field label / section header -->
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,8,0,3"/>
        </Style>
        <Style x:Key="Hdr" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.Accent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource Atlas.ComboBox}">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Width" Value="140"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
            <Setter Property="Margin" Value="0,7,0,0"/>
        </Style>
        <!-- Segmented panel ("card") -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Atlas.Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <!-- A short numeric box -->
        <Style x:Key="Num" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="120"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <!-- Sub-tab look: bottom-accent underline (matches Console). -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Padding="16,9" Margin="0,0,4,0"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Atlas.Brush.Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Atlas.Brush.TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Small chip for extension/URI lists -->
        <Style x:Key="ChipRemove" TargetType="Button" BasedOn="{StaticResource Atlas.Button.Nav}">
            <Setter Property="Padding" Value="3,0"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="MinWidth" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PreviewBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="MaxHeight" Value="220"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>

    </UserControl.Resources>

    <DockPanel Margin="16">

            <!-- Header -->
            <TextBlock DockPanel.Dock="Top" Text="{Binding ActiveProfileName}" FontSize="22" FontWeight="SemiBold"
                       Margin="0,0,0,10" Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>

            <!-- Persistent footer: one Save (whole model) + Launch, visible on every tab -->
            <Border DockPanel.Dock="Bottom" Margin="0,10,0,0" Padding="10,8"
                    Background="{DynamicResource Atlas.Brush.Surface}"
                    BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1" CornerRadius="4"
                    Visibility="{Binding HasActiveProfile, Converter={StaticResource BoolToVisibility}}">
                <DockPanel>
                    <Button DockPanel.Dock="Left" Content="Launch" Style="{StaticResource Atlas.Button.Primary}"
                            Command="{Binding LaunchCommand}" Margin="0,0,8,0"/>
                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="6,0,0,0"
                               Text="{Binding ActiveProfileName}" FontWeight="SemiBold"
                               Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Revert" Style="{StaticResource Atlas.Button.Secondary}"
                                Command="{Binding RevertCommand}" Margin="0,0,8,0"/>
                        <Button Content="Save" Style="{StaticResource Atlas.Button.Primary}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding HasActiveProfile, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <TextBlock Text="No active profile" FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource Atlas.Brush.TextPrimary}"/>
                <TextBlock Text="Create a profile or select one on the left to begin."
                           Margin="0,8,0,0" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
            </StackPanel>

            <!-- ===================== Tabs ===================== -->
            <TabControl Background="Transparent" BorderThickness="0"
                        Visibility="{Binding HasActiveProfile, Converter={StaticResource BoolToVisibility}}">

                <!-- ============== PROFILE ============== -->
                <TabItem Header="Profile">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0" VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource Hdr}" Text="IDENTITY"/>
                                        <TextBlock Style="{StaticResource Lbl}" Text="Profile name"/>
                                        <TextBox Text="{Binding Profile.Name}"/>
                                        <CheckBox Content="Set as default profile" IsChecked="{Binding Profile.IsDefault}"/>
                                        <TextBlock Style="{StaticResource Lbl}" Text="Notes"/>
                                        <TextBox Text="{Binding Profile.Notes}" AcceptsReturn="True" TextWrapping="Wrap"
                                                 Height="90" VerticalScrollBarVisibility="Auto"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource Hdr}" Text="EXECUTABLE"/>
                                        <TextBlock Style="{StaticResource Lbl}" Text="Server executable"/>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="Browse" Margin="8,0,0,0"
                                                    Style="{StaticResource Atlas.Button.Secondary}"
                                                    Command="{Binding BrowseServerExeCommand}"/>
                                            <TextBox Text="{Binding Profile.ServerExecutablePath}"/>
                                        </DockPanel>
                                        <TextBlock Style="{StaticResource Lbl}" Text="Server directory"/>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="Browse" Margin="8,0,0,0"
                                                    Style="{StaticResource Atlas.Button.Secondary}"
                                                    Command="{Binding BrowseServerDirCommand}"/>
                                            <TextBox Text="{Binding Profile.ServerDirectory}"/>
                                        </DockPanel>
                                        <CheckBox Content="Use profiling branch (arma3server_profiling_x64.exe)"
                                                  IsChecked="{Binding Profile.UseProfilingBranch}"/>
                                        <TextBlock Style="{StaticResource Lbl}" Text="Arma profile name (-name)"/>
                                        <TextBox Text="{Binding Profile.ArmaProfileName}"/>
                                        <TextBlock Style="{StaticResource Lbl}" Text="Game port"/>
                                        <TextBox Style="{StaticResource Num}" Text="{Binding Profile.Port}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Hdr}" Text="CREATOR DLC"/>
                                    <TextBlock Style="{StaticResource Lbl}"
                                               Text="Appended to -mod= by folder name; connecting players who own the DLC get full content."/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <CheckBox Width="210" Margin="0,4,8,4" Content="Contact" IsChecked="{Binding Profile.DlcContact}"/>
                                        <CheckBox Width="210" Margin="0,4,8,4" Content="Global Mobilization" IsChecked="{Binding Profile.DlcGlobalMobilization}"/>
                                        <CheckBox Width="210" Margin="0,4,8,4" Content="S.O.G. Prairie Fire" IsChecked="{Binding Profile.DlcPrairieFire}"/>
                                        <CheckBox Width="210" Margin="0,4,8,4" Content="CSLA Iron Curtain" IsChecked="{Binding Profile.DlcCsla}"/>
                                        <CheckBox Width="210" Margin="0,4,8,4" Content="Western Sahara" IsChecked="{Binding Profile.DlcWesternSahara}"/>
                                        <CheckBox Width="210" Margin="0,4,8,4" Content="Spearhead 1944" IsChecked="{Binding Profile.DlcSpearhead1944}"/>
                                        <CheckBox Width="210" Margin="0,4,8,4" Content="Reaction Forces" IsChecked="{Binding Profile.DlcReactionForces}"/>
                                        <CheckBox Width="210" Margin="0,4,8,4" Content="Expeditionary Forces" IsChecked="{Binding Profile.DlcExpeditionaryForces}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ============== MODS ============== -->
                <TabItem Header="Mods">
                    <DockPanel Margin="0,8,0,0">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                            <TextBlock DockPanel.Dock="Left" Style="{StaticResource Lbl}" Text="Mod preset" Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="Detach Preset" Style="{StaticResource Atlas.Button.Secondary}"
                                    Margin="8,0,0,0" Command="{Binding DetachPresetCommand}"/>
                            <ComboBox HorizontalAlignment="Stretch" Width="Auto"
                                      ItemsSource="{Binding PresetChoices}" DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedPresetChoice}"/>
                        </DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{Binding PresetInfo}" FontSize="11" Margin="0,0,0,6"
                                   TextWrapping="Wrap" Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                            <WrapPanel.Resources>
                                <Style TargetType="Button" BasedOn="{StaticResource Atlas.Button.Secondary}">
                                    <Setter Property="Margin" Value="0,0,6,6"/>
                                    <Setter Property="Padding" Value="9,4"/>
                                </Style>
                            </WrapPanel.Resources>
                            <Button Content="Add Workshop" Command="{Binding AddByWorkshopCommand}"/>
                            <Button Content="Add Local" Command="{Binding AddLocalCommand}"/>
                            <Button Content="Import A3" Command="{Binding ImportA3Command}"/>
                            <Button Content="Remove" Command="{Binding RemoveModCommand}"/>
                            <Button Content="Move Up" Command="{Binding MoveModUpCommand}"/>
                            <Button Content="Move Down" Command="{Binding MoveModDownCommand}"/>
                            <Button Content="Open in Workshop" Command="{Binding OpenInWorkshopCommand}"/>
                        </WrapPanel>
                        <DockPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                            <TextBlock DockPanel.Dock="Left" Text="{Binding ModSummary}" FontSize="11"
                                       Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="11" TextWrapping="Wrap" TextAlignment="Right"
                                       Foreground="{DynamicResource Atlas.Brush.TextDisabled}"
                                       Text="Update / deploy / download move to the global Mods tab (coming later)."/>
                        </DockPanel>
                        <Border Style="{StaticResource Card}" Padding="0">
                            <DataGrid ItemsSource="{Binding Mods}" SelectedItem="{Binding SelectedMod}"
                                      AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                                      CanUserSortColumns="True" GridLinesVisibility="All" Background="Transparent" BorderThickness="0"
                                      RowBackground="{DynamicResource Atlas.Brush.Surface}"
                                      Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                                      VerticalGridLinesBrush="Black"
                                      HorizontalGridLinesBrush="{DynamicResource Atlas.Brush.Border}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding LoadOrder}" IsReadOnly="True" Width="55" MinWidth="45"/>
                                    <DataGridTemplateColumn Header="Status" Width="64" MinWidth="58" IsReadOnly="True" CanUserSort="True"
                                                            SortMemberPath="UpdateAvailable">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Ellipse Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                         ToolTip="Grey = not checked · Amber = update available · Green = up to date">
                                                    <Ellipse.Fill>
                                                        <MultiBinding Converter="{StaticResource ModStatusToBrush}">
                                                            <Binding Path="LastChecked"/>
                                                            <Binding Path="UpdateAvailable"/>
                                                        </MultiBinding>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="240" MinWidth="120"/>
                                    <DataGridTextColumn Header="Workshop ID" Binding="{Binding WorkshopId}" IsReadOnly="True" Width="110" MinWidth="88"/>
                                    <DataGridCheckBoxColumn Header="Local" Binding="{Binding IsLocal}" IsReadOnly="True" Width="52" MinWidth="46"/>
                                    <DataGridTextColumn Header="Version" Binding="{Binding Version}" IsReadOnly="True" Width="72" MinWidth="56"/>
                                    <DataGridTextColumn Header="Last Updated"
                                                        Binding="{Binding LastUpdated, StringFormat=yyyy-MM-dd}"
                                                        IsReadOnly="True" Width="110" MinWidth="92"/>
                                    <DataGridTextColumn Header="Size"
                                                        Binding="{Binding SteamFileSize, Converter={StaticResource BytesToMb}}"
                                                        IsReadOnly="True" Width="72" MinWidth="56"/>
                                    <DataGridCheckBoxColumn Header="Server" Binding="{Binding EnabledForServer}" Width="62" MinWidth="54"/>
                                    <DataGridCheckBoxColumn Header="Client" Binding="{Binding EnabledForClient}" Width="62" MinWidth="54"/>
                                    <DataGridCheckBoxColumn Header="HC" Binding="{Binding EnabledForHeadless}" Width="48" MinWidth="42"/>
                                    <DataGridCheckBoxColumn Header="Optional" Binding="{Binding IsOptional}" Width="68" MinWidth="58"/>
                                    <DataGridCheckBoxColumn Header="Srv-only" Binding="{Binding IsServerOnly}" Width="68" MinWidth="58"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </DockPanel>
                </TabItem>

                <!-- ============== MISSIONS ============== -->
                <TabItem Header="Missions">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                        <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: mission list -->
                            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Hdr}" Text="MISSIONS"/>
                                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Lbl}" Text="Mission folder override (blank = &lt;ServerDir&gt;\MPMissions)"/>
                                    <DockPanel DockPanel.Dock="Top">
                                        <Button DockPanel.Dock="Right" Content="Browse" Margin="8,0,0,0"
                                                Style="{StaticResource Atlas.Button.Secondary}"
                                                Command="{Binding BrowseMissionDirCommand}"/>
                                        <TextBox Text="{Binding Profile.MissionDirectory}"/>
                                    </DockPanel>
                                    <Grid DockPanel.Dock="Top" Margin="0,8,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding MissionSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                                        <ComboBox Grid.Column="1" Margin="8,0,0,0" Width="150"
                                                  ItemsSource="{Binding Terrains}" SelectedItem="{Binding SelectedTerrain}"/>
                                    </Grid>
                                    <WrapPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                        <WrapPanel.Resources>
                                            <Style TargetType="Button" BasedOn="{StaticResource Atlas.Button.Secondary}">
                                                <Setter Property="Margin" Value="0,0,6,0"/>
                                                <Setter Property="Padding" Value="9,4"/>
                                            </Style>
                                        </WrapPanel.Resources>
                                        <Button Content="Clear Queue"
                                                Command="{Binding ClearMissionQueueCommand}"/>
                                        <Button Content="Open Folder" Command="{Binding OpenMissionFolderCommand}"/>
                                        <Button Content="Rescan" Command="{Binding ReloadMissionsCommand}"/>
                                    </WrapPanel>
                                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding MissionStatus}" FontSize="11" Margin="0,8,0,0"
                                               Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                                    <DataGrid ItemsSource="{Binding Missions}" SelectedItem="{Binding SelectedMission}"
                                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                              HeadersVisibility="Column" GridLinesVisibility="All"
                                              Background="Transparent" BorderThickness="0" MinHeight="280" Margin="0,8,0,0"
                                              RowBackground="{DynamicResource Atlas.Brush.Surface}"
                                              Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
                                              VerticalGridLinesBrush="Black"
                                              HorizontalGridLinesBrush="{DynamicResource Atlas.Brush.Border}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Mission" Binding="{Binding MissionName}" Width="280" MinWidth="160"/>
                                            <DataGridTextColumn Header="Terrain" Binding="{Binding Terrain}" Width="140" MinWidth="110"/>
                                            <DataGridTemplateColumn Header="Queue" Width="64" MinWidth="56">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                  IsChecked="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <!-- Right: mission parameters -->
                            <StackPanel Grid.Column="1">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource Hdr}" Text="MISSION PARAMETERS"/>
                                        <TextBlock Style="{StaticResource Lbl}" Text="Mission rotation (check missions in the list)"/>
                                        <TextBlock Text="{Binding QueueSummary}" TextWrapping="Wrap" Margin="0,0,0,8"
                                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}" FontSize="11"/>
                                        <TextBlock Style="{StaticResource Lbl}" Text="Single mission template (used only if none are checked)"/>
                                        <TextBox Text="{Binding Profile.MissionName}"/>
                                        <TextBlock Style="{StaticResource Lbl}" Text="Difficulty"/>
                                        <ComboBox Width="160" ItemsSource="{Binding DifficultyOptions}"
                                                  SelectedItem="{Binding Profile.MissionDifficulty}"/>
                                        <CheckBox Content="Auto-init persistent mission" IsChecked="{Binding Profile.AutoInit}"/>
                                        <CheckBox Content="Persistent" IsChecked="{Binding Profile.Persistent}"/>
                                        <CheckBox Content="Auto-select mission (skip mission list)" IsChecked="{Binding Profile.AutoSelectMission}"/>
                                        <CheckBox Content="Randomize mission order" IsChecked="{Binding Profile.RandomMissionOrder}"/>
                                        <CheckBox Content="Skip role-selection lobby" IsChecked="{Binding Profile.SkipLobby}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- DIFFICULTY (writes the server .Arma3Profile: CustomDifficulty + AI + view distance) -->
                        <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <Button DockPanel.Dock="Right" Content="Load preset → grid"
                                            Style="{StaticResource Atlas.Button.Secondary}"
                                            Command="{Binding ApplyDifficultyPresetCommand}"/>
                                    <TextBlock Style="{StaticResource Hdr}" Text="DIFFICULTY" VerticalAlignment="Center"/>
                                </DockPanel>
                                <TextBlock Style="{StaticResource Lbl}"
                                           Text="Set Difficulty (above) to &quot;Custom&quot; for these to apply. 'Load preset → grid' fills the grid from the chosen preset."/>
                                <WrapPanel Margin="0,4,0,0">
                                    <WrapPanel.Resources>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Width" Value="210"/>
                                            <Setter Property="Margin" Value="0,0,12,8"/>
                                        </Style>
                                    </WrapPanel.Resources>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="Group indicators"/><ComboBox ItemsSource="{Binding OnLimitedOptions}" SelectedIndex="{Binding Profile.DiffGroupIndicators, Mode=TwoWay}"/></StackPanel>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="Friendly tags"/><ComboBox ItemsSource="{Binding OnLimitedOptions}" SelectedIndex="{Binding Profile.DiffFriendlyTags, Mode=TwoWay}"/></StackPanel>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="Enemy tags"/><ComboBox ItemsSource="{Binding OnLimitedOptions}" SelectedIndex="{Binding Profile.DiffEnemyTags, Mode=TwoWay}"/></StackPanel>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="Detected mines"/><ComboBox ItemsSource="{Binding OnLimitedOptions}" SelectedIndex="{Binding Profile.DiffDetectedMines, Mode=TwoWay}"/></StackPanel>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="Commands"/><ComboBox ItemsSource="{Binding OnLimitedOptions}" SelectedIndex="{Binding Profile.DiffCommands, Mode=TwoWay}"/></StackPanel>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="Waypoints"/><ComboBox ItemsSource="{Binding OnLimitedOptions}" SelectedIndex="{Binding Profile.DiffWaypoints, Mode=TwoWay}"/></StackPanel>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="Weapon info"/><ComboBox ItemsSource="{Binding OnLimitedOptions}" SelectedIndex="{Binding Profile.DiffWeaponInfo, Mode=TwoWay}"/></StackPanel>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="Stance indicator"/><ComboBox ItemsSource="{Binding OnLimitedOptions}" SelectedIndex="{Binding Profile.DiffStanceIndicator, Mode=TwoWay}"/></StackPanel>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="3rd person view"/><ComboBox ItemsSource="{Binding ThirdPersonOptions}" SelectedIndex="{Binding Profile.DiffThirdPersonView, Mode=TwoWay}"/></StackPanel>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="AI skill (0-1)"/><TextBox Style="{StaticResource Num}" Text="{Binding Profile.SkillAI}"/></StackPanel>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="AI precision (0-1)"/><TextBox Style="{StaticResource Num}" Text="{Binding Profile.PrecisionAI}"/></StackPanel>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="View distance (0=default)"/><TextBox Style="{StaticResource Num}" Text="{Binding Profile.ViewDistance}"/></StackPanel>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="Object view distance"/><TextBox Style="{StaticResource Num}" Text="{Binding Profile.ObjectViewDistance}"/></StackPanel>
                                    <StackPanel><TextBlock Style="{StaticResource Lbl}" Text="Terrain grid (0=default)"/><TextBox Style="{StaticResource Num}" Text="{Binding Profile.TerrainGrid}"/></StackPanel>
                                </WrapPanel>
                                <WrapPanel Margin="0,2,0,0">
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="Reduced damage" IsChecked="{Binding Profile.DiffReducedDamage}"/>
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="Stamina bar" IsChecked="{Binding Profile.DiffStaminaBar}"/>
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="Weapon crosshair" IsChecked="{Binding Profile.DiffWeaponCrosshair}"/>
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="Vision aid" IsChecked="{Binding Profile.DiffVisionAid}"/>
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="Camera shake" IsChecked="{Binding Profile.DiffCameraShake}"/>
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="Score table" IsChecked="{Binding Profile.DiffScoreTable}"/>
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="Death messages" IsChecked="{Binding Profile.DiffDeathMessages}"/>
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="VoN ID" IsChecked="{Binding Profile.DiffVonID}"/>
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="Map content: friendly" IsChecked="{Binding Profile.DiffMapContentFriendly}"/>
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="Map content: enemy" IsChecked="{Binding Profile.DiffMapContentEnemy}"/>
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="Map content: mines" IsChecked="{Binding Profile.DiffMapContentMines}"/>
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="Auto report" IsChecked="{Binding Profile.DiffAutoReport}"/>
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="Multiple saves" IsChecked="{Binding Profile.DiffMultipleSaves}"/>
                                    <CheckBox Width="200" Margin="0,4,10,4" Content="Tactical ping" IsChecked="{Binding Profile.DiffTacticalPing}"/>
                                </WrapPanel>
                                <Expander Header="ARMA3PROFILE OUTPUT" Foreground="{DynamicResource Atlas.Brush.Accent}" Margin="0,8,0,0">
                                    <StackPanel Margin="0,8,0,0">
                                        <Button HorizontalAlignment="Left" Content="Refresh" Style="{StaticResource Atlas.Button.Secondary}"
                                                Command="{Binding RefreshPreviewCommand}" Margin="0,0,0,6"/>
                                        <TextBox Style="{StaticResource PreviewBox}" Text="{Binding Arma3ProfilePreview}"/>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ============== CONFIG (server.cfg) ============== -->
                <TabItem Header="Config">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Col 1: access + security -->
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="ACCESS"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Server hostname"/>
                                            <TextBox Text="{Binding Profile.ServerName}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Server password (join)"/>
                                            <TextBox Text="{Binding Profile.ServerPassword}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Admin password"/>
                                            <TextBox Text="{Binding Profile.AdminPassword}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Max players"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MaxPlayers}"/>
                                            <CheckBox Content="Server ranking enabled" IsChecked="{Binding Profile.RankingEnabled}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Ranking file"/>
                                            <TextBox Text="{Binding Profile.RankingFile}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="SECURITY"/>
                                            <CheckBox Content="BattlEye anti-cheat" IsChecked="{Binding Profile.EnableBattlEye}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Verify signatures (0=off, 1=v1, 2=v2)"/>
                                            <ComboBox ItemsSource="{Binding VerifySignaturesOptions}"
                                                      SelectedItem="{Binding Profile.VerifySignatures}"/>
                                            <CheckBox Content="Kick duplicate IDs" IsChecked="{Binding Profile.KickDuplicates}"/>
                                            <CheckBox Content="Require secure ID" IsChecked="{Binding Profile.RequiredSecureId}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Allowed file patching"/>
                                            <ComboBox ItemsSource="{Binding FilePatchingOptions}"
                                                      SelectedIndex="{Binding Profile.FilePatching, Mode=TwoWay}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Required client build (0 = any)"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.RequiredBuild}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Col 2: voice/voting + permissions/logging -->
                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="VOICE &amp; VOTING"/>
                                            <CheckBox Content="Disable VoN (voice over net)" IsChecked="{Binding Profile.DisableVoN}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="VoN codec quality (0-30)"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Slider x:Name="VonSlider" Minimum="0" Maximum="30" Width="180"
                                                        Value="{Binding Profile.VonCodecQuality}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Value, ElementName=VonSlider, StringFormat=N0}"
                                                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <CheckBox Content="Use legacy VoN codec (vonCodec = 0)" IsChecked="{Binding Profile.VonCodecLegacy}"/>
                                            <CheckBox Content="Voting enabled" IsChecked="{Binding Profile.VotingEnabled}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Vote threshold (0.0 - 1.0)"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.VoteThreshold}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Vote mission players"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.VoteMissionPlayers}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="PERMISSIONS &amp; LOGGING"/>
                                            <CheckBox Content="Allow drawing in map" IsChecked="{Binding Profile.DrawingInMap}"/>
                                            <CheckBox Content="Enable debug console" IsChecked="{Binding Profile.EnableDebugConsole}"/>
                                            <CheckBox Content="Short timestamp in logs" IsChecked="{Binding Profile.TimeStampFormat}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Log file name"/>
                                            <TextBox Text="{Binding Profile.LogFile}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="SCRIPTING CALLBACKS"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="serverCommandPassword"/>
                                            <TextBox Text="{Binding Profile.ServerCommandPassword}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="onUserConnected"/>
                                            <TextBox Text="{Binding Profile.OnUserConnected}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="onUserDisconnected"/>
                                            <TextBox Text="{Binding Profile.OnUserDisconnected}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="onHackedData"/>
                                            <TextBox Text="{Binding Profile.OnHackedData}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="onDifferentData"/>
                                            <TextBox Text="{Binding Profile.OnDifferentData}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="onUnsignedData"/>
                                            <TextBox Text="{Binding Profile.OnUnsignedData}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="onUserKicked"/>
                                            <TextBox Text="{Binding Profile.OnUserKicked}"/>
                                            <TextBlock Margin="0,8,0,0" FontSize="11" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource Atlas.Brush.TextDisabled}"
                                                       Text="Advanced: script/command strings run on these server events. Leave blank to omit."/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Col 3: MOTD + headless + extensions -->
                                <StackPanel Grid.Column="2">
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="MOTD"/>
                                            <TextBox Text="{Binding MotdText}" AcceptsReturn="True" TextWrapping="Wrap"
                                                     Height="70" VerticalScrollBarVisibility="Auto"/>
                                            <TextBlock Text="One line per row." FontSize="11" Margin="0,3,0,0"
                                                       Foreground="{DynamicResource Atlas.Brush.TextDisabled}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="MOTD interval (s)"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MotdInterval}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="HEADLESS CLIENTS"/>
                                            <CheckBox Content="Use headless clients" IsChecked="{Binding Profile.UseHeadlessClients}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Headless client count"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.HeadlessClientCount}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Headless executable (blank = same as server)"/>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="Browse" Margin="8,0,0,0"
                                                        Style="{StaticResource Atlas.Button.Secondary}"
                                                        Command="{Binding BrowseHeadlessExeCommand}"/>
                                                <TextBox Text="{Binding Profile.HeadlessClientExecutablePath}"/>
                                            </DockPanel>
                                            <CheckBox Content="Auto-restart headless clients on crash"
                                                      IsChecked="{Binding Profile.HeadlessAutoRestart}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="ALLOWED FILE EXTENSIONS"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Load file (allowedLoadFileExtensions)"/>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="Add" Margin="8,0,0,0"
                                                        Style="{StaticResource Atlas.Button.Secondary}"
                                                        Command="{Binding AddLoadExtensionCommand}"/>
                                                <TextBox Text="{Binding NewLoadExtension, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding LoadExtensions}" Margin="0,4,0,0">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource Atlas.Brush.SurfaceRaised}" CornerRadius="3"
                                                                Padding="6,2" Margin="0,4,4,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                                                <Button Style="{StaticResource ChipRemove}" Content="✕"
                                                                        Command="{Binding DataContext.RemoveLoadExtensionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Preprocess (allowedPreprocessFileExtensions)"/>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="Add" Margin="8,0,0,0"
                                                        Style="{StaticResource Atlas.Button.Secondary}"
                                                        Command="{Binding AddPreprocessExtensionCommand}"/>
                                                <TextBox Text="{Binding NewPreprocessExtension, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding PreprocessExtensions}" Margin="0,4,0,0">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource Atlas.Brush.SurfaceRaised}" CornerRadius="3"
                                                                Padding="6,2" Margin="0,4,4,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                                                <Button Style="{StaticResource ChipRemove}" Content="✕"
                                                                        Command="{Binding DataContext.RemovePreprocessExtensionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Style="{StaticResource Lbl}" Text="HTML load (allowedHTMLLoadExtensions)"/>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="Add" Margin="8,0,0,0"
                                                        Style="{StaticResource Atlas.Button.Secondary}"
                                                        Command="{Binding AddHtmlExtensionCommand}"/>
                                                <TextBox Text="{Binding NewHtmlExtension, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding HtmlExtensions}" Margin="0,4,0,0">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource Atlas.Brush.SurfaceRaised}" CornerRadius="3"
                                                                Padding="6,2" Margin="0,4,4,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                                                <Button Style="{StaticResource ChipRemove}" Content="✕"
                                                                        Command="{Binding DataContext.RemoveHtmlExtensionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Style="{StaticResource Lbl}" Text="HTML load URIs (allowedHTMLLoadURIs)"/>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="Add" Margin="8,0,0,0"
                                                        Style="{StaticResource Atlas.Button.Secondary}"
                                                        Command="{Binding AddHtmlUriCommand}"/>
                                                <TextBox Text="{Binding NewHtmlUri, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding HtmlUris}" Margin="0,4,0,0">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource Atlas.Brush.SurfaceRaised}" CornerRadius="3"
                                                                Padding="6,2" Margin="0,4,4,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                                                <Button Style="{StaticResource ChipRemove}" Content="✕"
                                                                        Command="{Binding DataContext.RemoveHtmlUriCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- server.cfg preview -->
                            <Expander Header="SERVER.CFG OUTPUT" Foreground="{DynamicResource Atlas.Brush.Accent}"
                                      Margin="0,4,0,0">
                                <StackPanel Margin="0,8,0,0">
                                    <DockPanel Margin="0,0,0,6">
                                        <Button DockPanel.Dock="Right" Content="Copy" Style="{StaticResource Atlas.Button.Secondary}"
                                                Command="{Binding CopyServerCfgCommand}"/>
                                        <Button HorizontalAlignment="Left" Content="Refresh" Style="{StaticResource Atlas.Button.Secondary}"
                                                Command="{Binding RefreshPreviewCommand}"/>
                                    </DockPanel>
                                    <TextBox Style="{StaticResource PreviewBox}" Text="{Binding ServerCfgPreview}"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ============== NETWORK (network + basic.cfg + perf) ============== -->
                <TabItem Header="Network">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Col 1: connection -->
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="CONNECTION"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Max ping"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MaxPing}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Max desync"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MaxDesync}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Max packet loss"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MaxPacketLoss}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Disconnect timeout (s)"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.DisconnectTimeout}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Max disconnect timeout (s)"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MaxDisconnectTimeout}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Max custom file size (bytes, 0 = no limit)"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MaxCustomFileSize}"/>
                                            <CheckBox Content="Loopback" IsChecked="{Binding Profile.Loopback}"/>
                                            <CheckBox Content="UPnP (auto port-forward)" IsChecked="{Binding Profile.Upnp}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="RCON (BATTLEYE)"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="RCON password"/>
                                            <TextBox Text="{Binding Profile.RconPassword}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="RCON port"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.RconPort}"/>
                                            <TextBlock Text="Avoid 2302-2306 (reserved by the game). Defaults: 2301, 2307, 2310."
                                                       Foreground="{DynamicResource Atlas.Brush.Warning}" FontSize="11"
                                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Col 2: bandwidth (basic.cfg) -->
                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="BANDWIDTH (basic.cfg)"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Min bandwidth (bps)"/>
                                            <TextBox Width="180" HorizontalAlignment="Left" Text="{Binding Profile.MinBandwidth}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Max bandwidth (bps)"/>
                                            <TextBox Width="180" HorizontalAlignment="Left" Text="{Binding Profile.MaxBandwidth}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Max msg send"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MaxMsgSend}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Max size guaranteed"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MaxSizeGuaranteed}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Max size non-guaranteed"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MaxSizeNonguaranteed}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Min error to send"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MinErrorToSend}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Min error to send near"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MinErrorToSendNear}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Max packet size (basic.cfg)"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MaxPacketSize}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Col 3: performance + launch flags + crash/custom -->
                                <StackPanel Grid.Column="2">
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="PERFORMANCE"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="CPU count (0 = auto)"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.CpuCount}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Extra threads (-exThreads)"/>
                                            <ComboBox ItemsSource="{Binding ExThreadsOptions}" SelectedItem="{Binding Profile.ExThreads}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Max memory MB (0 = auto)"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MaxMem}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Malloc"/>
                                            <TextBox Text="{Binding Profile.Malloc}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Bandwidth algorithm"/>
                                            <ComboBox ItemsSource="{Binding BandwidthAlgOptions}" SelectedItem="{Binding Profile.BandwidthAlg}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Limit FPS (0 = no limit)"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.LimitFPS}"/>
                                            <CheckBox Content="Enable hyper-threading (-enableHT)" IsChecked="{Binding Profile.EnableHT}"/>
                                            <CheckBox Content="Huge pages (-hugePages)" IsChecked="{Binding Profile.HugePages}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="LAUNCH FLAGS"/>
                                            <CheckBox Content="No sound (-nosound)" IsChecked="{Binding Profile.NoSound}"/>
                                            <CheckBox Content="No splash (-nosplash)" IsChecked="{Binding Profile.NoSplash}"/>
                                            <CheckBox Content="Skip intro (-skipIntro)" IsChecked="{Binding Profile.SkipIntro}"/>
                                            <CheckBox Content="World empty (-world=empty)" IsChecked="{Binding Profile.WorldEmpty}"/>
                                            <CheckBox Content="No pause (-noPause)" IsChecked="{Binding Profile.NoPause}"/>
                                            <CheckBox Content="No logs (-nologs)" IsChecked="{Binding Profile.NoLogs}"/>
                                            <CheckBox Content="Net log (-netlog)" IsChecked="{Binding Profile.NetLog}"/>
                                            <CheckBox Content="Load mission to memory" IsChecked="{Binding Profile.LoadMissionToMemory}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Hdr}" Text="CRASH / CUSTOM"/>
                                            <CheckBox Content="Auto-restart on crash" IsChecked="{Binding Profile.AutoRestartOnCrash}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Auto-restart delay (s)"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.AutoRestartDelaySeconds}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Max crashes before giving up (0 = unlimited)"/>
                                            <TextBox Style="{StaticResource Num}" Text="{Binding Profile.MaxCrashesBeforeGiveUp}"/>
                                            <TextBlock Style="{StaticResource Lbl}" Text="Custom launch parameters (appended verbatim)"/>
                                            <TextBox Text="{Binding Profile.CustomLaunchParameters}" AcceptsReturn="True"
                                                     TextWrapping="Wrap" Height="50" VerticalScrollBarVisibility="Auto"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- basic.cfg + command line preview -->
                            <Expander Header="BASIC.CFG / COMMAND LINE" Foreground="{DynamicResource Atlas.Brush.Accent}"
                                      Margin="0,4,0,0">
                                <StackPanel Margin="0,8,0,0">
                                    <DockPanel Margin="0,0,0,6">
                                        <Button DockPanel.Dock="Right" Content="Copy cmd" Style="{StaticResource Atlas.Button.Secondary}"
                                                Command="{Binding CopyLaunchCommandCommand}" Margin="6,0,0,0"/>
                                        <Button DockPanel.Dock="Right" Content="Copy basic.cfg" Style="{StaticResource Atlas.Button.Secondary}"
                                                Command="{Binding CopyBasicCfgCommand}"/>
                                        <Button HorizontalAlignment="Left" Content="Refresh" Style="{StaticResource Atlas.Button.Secondary}"
                                                Command="{Binding RefreshPreviewCommand}"/>
                                    </DockPanel>
                                    <TextBox Style="{StaticResource PreviewBox}" Text="{Binding BasicCfgPreview}" MaxHeight="150"/>
                                    <TextBlock Style="{StaticResource Lbl}" Text="Launch command"/>
                                    <TextBox Style="{StaticResource PreviewBox}" Text="{Binding LaunchCommandPreview}"
                                             MaxHeight="90" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
    </DockPanel>
</UserControl>
