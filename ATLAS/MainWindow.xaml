<Window x:Class="Atlas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ATLAS — Arma Tactical Launch and Administration System"
        Icon="pack://application:,,,/Resources/atlas_icon.ico"
        Width="1280" Height="800" MinWidth="1000" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Atlas.Brush.Background}"
        TextElement.Foreground="{DynamicResource Atlas.Brush.TextPrimary}"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI" FontSize="13">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===================== Sidebar ===================== -->
        <Border Grid.Column="0" Background="{DynamicResource Atlas.Brush.Surface}"
                BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Wordmark -->
                <Border DockPanel.Dock="Top" Height="48" Padding="14,0"
                        BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Shield" Width="24" Height="24"
                                                 Foreground="{DynamicResource Atlas.Brush.Accent}"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="ATLAS" FontSize="18" FontWeight="Bold" Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding SidebarCollapsed, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                    </StackPanel>
                </Border>

                <!-- Collapse toggle pinned to the bottom -->
                <Button DockPanel.Dock="Bottom" Height="44" Style="{StaticResource Atlas.Button.Nav}"
                        Command="{Binding ToggleSidebarCommand}" ToolTip="Collapse / expand">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="DockLeft" Width="22" Height="22" VerticalAlignment="Center"/>
                        <TextBlock Text="Collapse" Margin="14,0,0,0" VerticalAlignment="Center"
                                   Visibility="{Binding SidebarCollapsed, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                    </StackPanel>
                </Button>

                <!-- Nav items -->
                <ItemsControl ItemsSource="{Binding NavItems}" DockPanel.Dock="Top">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Height="44" Style="{StaticResource Atlas.Button.Nav}"
                                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding Key}"
                                    ToolTip="{Binding Label}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="{Binding Icon}" Width="22" Height="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Label}" Margin="14,0,0,0" VerticalAlignment="Center"
                                               Visibility="{Binding DataContext.SidebarCollapsed, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- ===================== Right side ===================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="16,0" Background="{DynamicResource Atlas.Brush.Surface}"
                    BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Text="{Binding ActiveProfileName}"
                               Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                    <Border Grid.Column="1" CornerRadius="10" Padding="12,4" VerticalAlignment="Center"
                            Background="{DynamicResource Atlas.Brush.SurfaceRaised}"
                            BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                     Fill="{DynamicResource Atlas.Brush.TextSecondary}"/>
                            <TextBlock Text="{Binding ServerStatusText}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"
                               Text="{Binding VersionText}"
                               Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                </Grid>
            </Border>

            <!-- Page content (with the non-blocking update banner overlaid at the top) -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16,10"
                        Background="{DynamicResource Atlas.Brush.Accent}"
                        Visibility="{Binding UpdateBannerVisible, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap"
                                   Foreground="White" Text="{Binding UpdateBannerText}"/>
                        <Button Grid.Column="1" Content="View Release" Margin="0,0,8,0"
                                Background="White" Foreground="{DynamicResource Atlas.Brush.Accent}"
                                BorderThickness="0" Padding="12,5" Cursor="Hand"
                                Command="{Binding ViewReleaseCommand}"/>
                        <Button Grid.Column="2" Content="Dismiss"
                                Background="Transparent" Foreground="White"
                                BorderBrush="White" BorderThickness="1" Padding="12,5" Cursor="Hand"
                                Command="{Binding DismissUpdateCommand}"/>
                    </Grid>
                </Border>

                <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="2" Padding="12,0" Background="{DynamicResource Atlas.Brush.Surface}"
                    BorderBrush="{DynamicResource Atlas.Brush.Border}" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock VerticalAlignment="Center" FontSize="12"
                               Text="{Binding LastActionMessage}"
                               Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Uptime" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource Atlas.Brush.TextDisabled}"/>
                        <TextBlock Text="{Binding UptimeText}" VerticalAlignment="Center" FontSize="12" Margin="6,0,16,0"
                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                        <materialDesign:PackIcon Kind="AccountGroup" Width="14" Height="14" VerticalAlignment="Center"
                                                 Foreground="{DynamicResource Atlas.Brush.TextDisabled}"/>
                        <TextBlock Text="{Binding PlayerCount}" VerticalAlignment="Center" FontSize="12" Margin="6,0,0,0"
                                   Foreground="{DynamicResource Atlas.Brush.TextSecondary}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
